<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>Lyo.Web.Reporting</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>Powerful fluent API for building and rendering professional reports in .NET applications. Built on Blazor components with support for sections, columns, grids,
            content blocks, and metrics visualizations.
        </description>
        <summary>Report building and rendering library for .NET</summary>
        <readme>README.md</readme>
        <copyright>Copyright © Lyo</copyright>
        <tags>blazor reporting reports charts metrics visualization</tags>
        <repository type="git" url="https://github.com/mjwherry/Lyo"/>
        <dependencies>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Metrics" version="[1.0.71,)"/>
                <dependency id="Microsoft.AspNetCore.Components.Web" version="10.*"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="README.md" target=""/>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
