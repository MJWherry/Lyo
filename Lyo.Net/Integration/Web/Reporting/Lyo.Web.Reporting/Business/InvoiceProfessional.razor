@* InvoiceProfessional.razor - Biller/Customer side-by-side, tax/shipping *@

@code {

    public sealed record InvoiceProfessionalOptions(string InvoiceNumber, DateTime InvoiceDate, DateTime DueDate, string BillerName, string BillerAddress, string BillerEmail, string BillerPhone, string CustomerName, string CustomerAddress, string CustomerEmail, List<InvoiceProfessionalLineItem> LineItems, decimal? TaxRate, decimal? ShippingAmount, string PaymentTerms)
    {
        public decimal Subtotal => LineItems.Sum(i => i.Total);

        public decimal TaxAmount => TaxRate.HasValue ? Subtotal * TaxRate.Value : 0;

        public decimal Shipping => ShippingAmount ?? 0;

        public decimal GrandTotal => Subtotal + TaxAmount + Shipping;
    }

    public sealed record InvoiceProfessionalLineItem(string Description, string? Sku, int Quantity, decimal UnitPrice)
    {
        public decimal Total => Quantity * UnitPrice;
    }

    [Parameter]
    [EditorRequired]
    public InvoiceProfessionalOptions Options { get; set; } = null!;

}

<div style="max-width: 800px; margin: 40px auto; padding: 50px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
    <div style="display: flex; justify-content: space-between; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 2px solid #0f172a;">
        <div>
            <h1 style="margin: 0; font-size: 28px; color: #0f172a;">@Options.BillerName</h1>
            <div style="color: #64748b; margin-top: 8px; font-size: 14px;">@Options.BillerAddress</div>
            <div style="color: #64748b; font-size: 13px;">@Options.BillerEmail | @Options.BillerPhone</div>
        </div>
        <div style="text-align: right;">
            <div style="font-size: 12px; color: #64748b; text-transform: uppercase;">Invoice</div>
            <div style="font-size: 24px; font-weight: 700; color: #0f172a;">#@Options.InvoiceNumber</div>
            <div style="font-size: 13px; margin-top: 12px;">Date: @Options.InvoiceDate.ToString("MMM d, yyyy")</div>
            <div style="font-size: 13px;">Due: @Options.DueDate.ToString("MMM d, yyyy")</div>
        </div>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 40px;">
        <div>
            <div style="font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; margin-bottom: 8px;">Bill To</div>
            <div style="font-weight: 600; color: #0f172a;">@Options.CustomerName</div>
            <div style="color: #475569; font-size: 14px;">@Options.CustomerAddress</div>
            <div style="color: #475569; font-size: 14px;">@Options.CustomerEmail</div>
        </div>
    </div>
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
        <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
            <th style="padding: 12px; text-align: left; font-size: 11px; font-weight: 600; color: #64748b;">Description</th>
            <th style="padding: 12px; text-align: center; font-size: 11px; font-weight: 600; color: #64748b;">SKU</th>
            <th style="padding: 12px; text-align: right; font-size: 11px; font-weight: 600; color: #64748b;">Qty</th>
            <th style="padding: 12px; text-align: right; font-size: 11px; font-weight: 600; color: #64748b;">Unit Price</th>
            <th style="padding: 12px; text-align: right; font-size: 11px; font-weight: 600; color: #64748b;">Amount</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Options.LineItems) {
            <tr style="border-bottom: 1px solid #e2e8f0;">
                <td style="padding: 16px;">@item.Description</td>
                <td style="padding: 16px; text-align: center;">@(item.Sku ?? "—")</td>
                <td style="padding: 16px; text-align: right;">@item.Quantity</td>
                <td style="padding: 16px; text-align: right;">$@item.UnitPrice.ToString("N2")</td>
                <td style="padding: 16px; text-align: right; font-weight: 500;">$@item.Total.ToString("N2")</td>
            </tr>
        }
        </tbody>
    </table>
    <div style="margin-top: 24px; margin-left: auto; width: 280px;">
        <div style="display: flex; justify-content: space-between; padding: 8px 0;"><span>Subtotal</span><span>$@Options.Subtotal.ToString("N2")</span></div>
        @if (Options.TaxRate.HasValue) {
            <div style="display: flex; justify-content: space-between; padding: 8px 0;">
                <span>Tax (@((Options.TaxRate.Value * 100).ToString("F0"))%)</span><span>$@Options.TaxAmount.ToString("N2")</span></div>
        }
        @if (Options.ShippingAmount.HasValue && Options.ShippingAmount > 0) {
            <div style="display: flex; justify-content: space-between; padding: 8px 0;"><span>Shipping</span><span>$@Options.Shipping.ToString("N2")</span></div>
        }
        <div style="display: flex; justify-content: space-between; padding: 16px 0; font-size: 18px; font-weight: 700; border-top: 2px solid #0f172a;">
            <span>Total Due</span><span>$@Options.GrandTotal.ToString("N2")</span></div>
    </div>
    <div style="margin-top: 50px; padding-top: 20px; border-top: 1px solid #e2e8f0; font-size: 13px; color: #64748b;">Payment Terms: @Options.PaymentTerms</div>
</div>
