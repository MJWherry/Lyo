@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@typeparam T

<div class="unique-value-selector">
    <MudTextField @bind-Value="@SearchText"
                  Placeholder="Search values..."
                  Variant="Variant.Outlined"
                  DebounceInterval="300"
                  Immediate="false"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Class="mb-2"
                  Margin="Margin.Dense"/>

    <div class="d-flex justify-space-between align-center mb-2">
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            @(_selectedValues.Count) of @(_filteredItems.Count) selected
        </MudText>
        <div class="d-flex gap-1">
            <MudButton Size="Size.Small"
                       Variant="Variant.Text"
                       Class="lyo-unique-toolbar-action"
                       Ripple="false"
                       OnClick="SelectAll"
                       Disabled="@(_filteredItems.Count == 0)">
                Select All
            </MudButton>
            <MudButton Size="Size.Small"
                       Variant="Variant.Text"
                       Class="lyo-unique-toolbar-action"
                       Ripple="false"
                       OnClick="ClearAll"
                       Disabled="@(_selectedValues.Count == 0)">
                Clear
            </MudButton>
        </div>
    </div>

    <MudPaper Elevation="0"
              Class="unique-value-listbox pa-2"
              Style="max-height: 300px; overflow-y: auto; border: 1px solid var(--mud-palette-divider);">
        @if (IsLoading) {
            <div class="d-flex flex-column align-center justify-center pa-4">
                <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true"/>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">Loading...</MudText>
            </div>
        }
        else if (_filteredItems.Any()) {
            @* Use div+role=button (not nested &lt;button&gt;) so clicks work inside MudMenu popovers. *@
            @foreach (var item in _filteredItems) {
                var value = item.Value ?? string.Empty;
                var isSelected = _selectedValues.Contains(value);
                <div role="button"
                     tabindex="0"
                     class="unique-value-item d-flex align-center pa-2 @(isSelected ? "selected" : "")"
                     @onclick="@(() => ToggleSelection(value))"
                     @onkeydown="@((KeyboardEventArgs e) => OnRowKeyDown(e, value))">
                    <MudIcon Icon="@(isSelected ? Icons.Material.Filled.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)"
                             Size="Size.Small"
                             Class="flex-shrink-0"
                             Style="pointer-events: none;"/>
                    <div class="flex-grow-1 ml-2 text-start" style="min-width: 0;">
                        <MudText Typo="Typo.body2">
                            @(FormatValue(item.Value))
                        </MudText>
                    </div>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary ma-0 flex-shrink-0">
                        @item.Count.ToString("N0")
                    </MudText>
                </div>
            }
        }
        else {
            <div class="d-flex flex-column align-center justify-center pa-4">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Class="mb-2"/>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">No matching values</MudText>
            </div>
        }
    </MudPaper>
</div>

<style>
    .unique-value-selector {
        min-width: 0;
        width: min(28rem, 100%);
        max-width: 100%;
    }

    .unique-value-listbox {
        background-color: var(--mud-palette-surface);
    }

    .unique-value-item {
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
        font: inherit;
        color: inherit;
        cursor: pointer;
        border-radius: var(--mud-default-borderradius);
        outline: none;
    }

    .unique-value-item.selected {
        background-color: var(--mud-palette-action-selected) !important;
    }

    .unique-value-item:focus-visible {
        box-shadow: inset 0 0 0 2px var(--mud-palette-primary);
    }

    .lyo-unique-toolbar-action:hover {
        background-color: transparent !important;
    }
</style>
