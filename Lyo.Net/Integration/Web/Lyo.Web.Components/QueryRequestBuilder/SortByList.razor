@using MudBlazor
@using SortDirectionEnum = Lyo.Common.Enums.SortDirection

<MudStack Spacing="1">
    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
        <MudTextField T="string"
                      @bind-Value="_newProperty"
                      Label="Property"
                      Variant="Variant.Outlined"
                      Dense
                      Immediate
                      Margin="Margin.Dense"
                      OnKeyDown="@OnKeyDown"
                      Style="flex: 1; min-width: 80px;"/>
        <MudSelect T="SortDirectionEnum"
                   @bind-Value="_newDirection"
                   Label="Direction"
                   Variant="Variant.Outlined"
                   Dense
                   Margin="Margin.Dense"
                   Style="min-width: 80px;">
            <MudSelectItem Value="@SortDirectionEnum.Asc">Asc</MudSelectItem>
            <MudSelectItem Value="@SortDirectionEnum.Desc">Desc</MudSelectItem>
        </MudSelect>
        <MudNumericField T="int?"
                         @bind-Value="_newPriority"
                         Label="Priority"
                         Variant="Variant.Outlined"
                         Dense
                         Margin="Margin.Dense"
                         Min="0"
                         Style="min-width: 60px;"/>
        <MudIconButton Icon="@Icons.Material.Filled.Add"
                       Color="Color.Primary"
                       Size="Size.Small"
                       OnClick="@AddSort"
                       Disabled="@string.IsNullOrWhiteSpace(_newProperty)"
                       Title="Add sort"/>
    </MudStack>

    @if (Items.Any()) {
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
            @foreach (var (item, i) in Items.Select((s, idx) => (s, idx))) {
                var index = i;
                <MudChip T="string"
                         Size="Size.Small"
                         Variant="Variant.Filled"
                         Color="Color.Primary"
                         OnClose="@(() => RemoveSort(index))">
                    @FormatChipText(item)
                </MudChip>
            }
        </MudStack>
    }
</MudStack>
