@using MudBlazor
<MudGrid>
    <MudItem xs="12" sm="6">
        <MudNumericField T="int?"
                         Value="@Start"
                         ValueChanged="@(v => OnStartChanged(v))"
                         Label="Start"
                         Variant="Variant.Outlined"
                         Dense
                         Margin="Margin.Dense"
                         Min="0"
                         Placeholder="0"/>
    </MudItem>
    <MudItem xs="12" sm="6">
        <MudNumericField T="int?"
                         Value="@Amount"
                         ValueChanged="@(v => OnAmountChanged(v))"
                         Label="Amount"
                         Variant="Variant.Outlined"
                         Dense
                         Margin="Margin.Dense"
                         Min="1"
                         Placeholder="20"/>
    </MudItem>
</MudGrid>

