@using Lyo.Query.Models.Common
@using MudBlazor
<MudContainer Class="query-node-editor-container" Style="padding: 0;">
    @if (_rootNode != null) {
        <MudGrid Class="query-node-editor-grid">
            @* Left Column - Tree View (1/3) *@
            <MudItem xs="12" md="4" Class="query-node-editor-column">
                <MudPaper Elevation="1" Class="pa-2 query-node-editor-panel">
                    <div class="query-structure-layout">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">Query Structure</MudText>
                        <style>
                            .drag-over-group-clause {
                                background-color: rgba(25, 118, 210, 0.1) !important;
                                border: 2px dashed #1976d2 !important;
                                border-radius: 4px;
                            }

                            .dragging-node {
                                opacity: 0.5;
                            }
                        </style>

                        <div class="query-structure-scroll">
                            <MudTreeView T="WhereClauseTreeItem" Items="@_treeItems" Hover="true" Dense="true">
                                <ItemTemplate Context="treeItem">
                                    <div class="@(treeItem.Value.Node == _draggedNode ? "dragging-node" : "")"
                                         @ondragover="@DragOverCallback(treeItem.Value.Node)"
                                         @ondragover:preventDefault="true"
                                         @ondragover:stopPropagation="true"
                                         @ondragleave="@OnDragLeave"
                                         @ondrop="@DropCallback(treeItem.Value.Node)"
                                         @ondrop:preventDefault="true"
                                         @ondrop:stopPropagation="true"
                                         style="@($"{(treeItem.Value.Node == _dragOverNode && treeItem.Value.Node is GroupClause ? "background-color: rgba(25, 118, 210, 0.1); border: 2px dashed #1976d2; border-radius: 4px; padding: 2px;" : "")} cursor: {GetDragCursor()};")">
                                        <MudTreeViewItem @key="@treeItem.Value.Node"
                                                         Value="@treeItem.Value"
                                                         Items="@treeItem.Children"
                                                         Icon="@GetNodeIcon(treeItem.Value.Node)"
                                                         IconColor="@GetNodeIconColor(treeItem.Value.Node)"
                                                         Selected="@(treeItem.Value.Node == _selectedNode)"
                                                         OnClick="@(() => SelectNode(treeItem.Value.Node))">
                                            <BodyContent>
                                                <div style="display: flex; align-items: center; width: 100%; gap: 4px;"
                                                     @onclick:stopPropagation="true">
                                                    @if (AllowDragDrop) {
                                                        <span draggable="true"
                                                              ondragstart="event.dataTransfer.effectAllowed='move'; event.dataTransfer.setData('text/plain', 'query-node');"
                                                              @ondragend="@OnDragEnd"
                                                              @onmousedown="@(() => PrepareDrag(treeItem.Value.Node))"
                                                              @onmousedown:stopPropagation="true"
                                                              style="display: inline-flex; align-items: center; cursor: move; user-select: none; -webkit-user-drag: element;"
                                                              title="Drag to move">
                                                            <MudIcon Icon="@Icons.Material.Filled.DragHandle"
                                                                     Size="Size.Small"
                                                                     Class="mud-text-secondary"
                                                                     Style="@($"cursor: {GetDragCursor()};")"/>
                                                        </span>
                                                    }
                                                    <span style="flex: 1;"
                                                          @onclick="@(() => SelectNode(treeItem.Value.Node))">@GetNodeDisplayText(treeItem.Value.Node)</span>
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                   Color="Color.Error"
                                                                   Size="Size.Small"
                                                                   OnClick="@(() => RemoveNode(treeItem.Value.Node))"
                                                                   Title="Remove node"/>
                                                </div>
                                            </BodyContent>
                                        </MudTreeViewItem>
                                    </div>
                                </ItemTemplate>
                            </MudTreeView>
                        </div>

                        <div class="query-structure-footer">
                            <MudDivider Class="my-3"/>

                            <MudStack Row="true" Spacing="1" Class="query-structure-actions">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="@(() => AddGroupClauseAtSelected())"
                                           Disabled="@(_selectedNode == null || _selectedNode is ConditionClause)">
                                    Group clause
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Secondary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="@(() => AddConditionClauseAtSelected())"
                                           Disabled="@(_selectedNode == null || _selectedNode is ConditionClause)">
                                    Condition clause
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="@AddSubClauseAtSelected"
                                           Disabled="@(!CanAddSubClause(_selectedNode))">
                                    SubQuery
                                </MudButton>
                            </MudStack>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            @* Right Column - Node Editor (2/3) *@
            <MudItem xs="12" md="8" Class="query-node-editor-column">
                <MudPaper Elevation="1" Class="pa-3 query-node-editor-panel" Style="overflow-y: auto;">
                    @if (_selectedNode != null) {
                        <MudStack Spacing="2">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Style="flex: 1;">Node Editor</MudText>
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Delete"
                                           OnClick="@(() => RemoveNode(_selectedNode))">
                                    Remove Node
                                </MudButton>
                            </MudStack>
                            <MudDivider/>
                            <QueryNodeEditor @ref="_nodeEditorRef"
                                             Node="@_selectedNode"
                                             PropertyDefinitions="@PropertyDefinitions"
                                             OnNodeChanged="@HandleNodeChanged"
                                             OnChildSelected="@SelectNode"/>
                        </MudStack>
                    }
                    else {
                        <MudAlert Severity="Severity.Info">
                            Select a node from the tree to edit, or add a new node to get started.
                        </MudAlert>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else {
        <MudStack Spacing="3" AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 300px;">
            <MudText Typo="Typo.h6">Start Building Your Query</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                Choose how to start your query:
            </MudText>
            <MudStack Row="true" Spacing="3" Justify="Justify.Center">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.AccountTree"
                           OnClick="@AddGroupClause">
                    Add group clause
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Secondary"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.FilterList"
                           OnClick="@AddConditionClause">
                    Add condition clause
                </MudButton>
            </MudStack>
        </MudStack>
    }
</MudContainer>

<style>
    .query-node-editor-container {
        height: 600px;
        max-height: 600px;
    }

    .query-node-editor-grid {
        height: 100%;
    }

    .query-node-editor-column {
        height: 100%;
        min-height: 0;
        display: flex;
    }

    .query-node-editor-panel {
        width: 100%;
        height: 100%;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    .query-structure-scroll {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .query-structure-layout {
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 0;
    }

    .query-structure-footer {
        flex: 0 0 auto;
    }

    .query-structure-actions {
        width: 100%;
    }

    .query-structure-actions .mud-button-root {
        flex: 1 1 0;
        min-width: 0;
    }

    .query-structure-actions .mud-button-root:disabled {
        opacity: 0.7;
        color: rgba(255, 255, 255, 0.7) !important;
        border-color: rgba(255, 255, 255, 0.25) !important;
    }

    @@media (max-width: 960px) {
        .query-node-editor-container {
            height: auto;
            max-height: none;
        }

        .query-node-editor-grid,
        .query-node-editor-column,
        .query-node-editor-panel {
            height: auto;
        }

        .query-structure-scroll {
            max-height: 300px;
        }
    }
</style>
