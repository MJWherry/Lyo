@using MudBlazor
<MudTextField T="string?"
              Label="@Label"
              Value="@(Value ?? "")"
              ValueChanged="HandleValueChanged"
              Placeholder="@(Value == null ? "null" : Placeholder)"
              Immediate="true"
              ReadOnly="ReadOnly"
              Disabled="Disabled"
              Variant="Variant"
              Margin="Margin"
              Adornment="Adornment.End"
              AdornmentIcon="@Icons.Material.Filled.Clear"
              OnAdornmentClick="HandleClearClick"/>

