@inject ISnackbar Snackbar

<MudGrid Class="pa-4">
    <MudItem xs="12" md="4">
        <MudPaper Elevation="1" Class="pa-2" Style="height: 600px; overflow-y: auto;">
            <MudStack Spacing="2">
                <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h6">Schedules</MudText>
                </MudStack>
                <MudList T="JobScheduleRes" Dense>
                    @if (JobSchedules?.Any() == true) {
                        @foreach (var s in JobSchedules) {
                            <MudListItem T="JobScheduleRes" OnClick="@(() => _selected = s)"
                                         Class="@(_selected?.Id == s.Id ? "mud-primary" : "")" Style="cursor:pointer;">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(s.Enabled ? Color.Success : Color.Error)"
                                             Icon="@(s.Enabled ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                             OnClick="@(() => ToggleSchedule(s))" Style="cursor:pointer;">
                                        @s.Type
                                    </MudChip>
                                    <MudText Typo="Typo.body2">@(s.Description ?? s.ToString())</MudText>
                                </MudStack>
                            </MudListItem>
                        }
                    }
                    else {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No schedules</MudText>
                    }
                </MudList>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="8">
        @if (_selected != null) {
            <MudPaper Elevation="1" Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Schedule Details</MudText>
                    <MudGrid>
                        <MudItem xs="6"><MudText Typo="Typo.body2"><b>Type:</b> @_selected.Type</MudText></MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.body2"><b>Description:</b> @(_selected.Description ?? "-")</MudText></MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.body2"><b>Days:</b> @_selected.DayFlags</MudText></MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.body2"><b>Months:</b> @_selected.MonthFlags</MudText></MudItem>
                        @if (_selected.CronExpression != null) {
                            <MudItem xs="12"><MudText Typo="Typo.body2"><b>Cron:</b> @_selected.CronExpression</MudText></MudItem>
                        }
                        @if (_selected.StartTime != null || _selected.EndTime != null) {
                            <MudItem xs="6"><MudText Typo="Typo.body2"><b>Start:</b> @(_selected.StartTime?.ToString("HH:mm") ?? "-")</MudText></MudItem>
                            <MudItem xs="6"><MudText Typo="Typo.body2"><b>End:</b> @(_selected.EndTime?.ToString("HH:mm") ?? "-")</MudText></MudItem>
                        }
                        @if (_selected.IntervalMinutes != null) {
                            <MudItem xs="6"><MudText Typo="Typo.body2"><b>Interval (min):</b> @_selected.IntervalMinutes</MudText></MudItem>
                        }
                        @if (_selected.Times?.Any() == true) {
                            <MudItem xs="12">
                                <MudText Typo="Typo.body2"><b>Times:</b></MudText>
                                <MudStack Row Spacing="1" Wrap="Wrap.Wrap">
                                    @foreach (var t in _selected.Times) {
                                        <MudChip T="string" Size="Size.Small">@t.ToString("HH:mm")</MudChip>
                                    }
                                </MudStack>
                            </MudItem>
                        }
                    </MudGrid>
                    @if (_selected.Parameters?.Any() == true) {
                        <MudDivider/>
                        <MudText Typo="Typo.h6">Schedule Parameters</MudText>
                        <MudGrid>
                            @foreach (var p in _selected.Parameters) {
                                <MudItem xs="12" md="6">
                                    <MudPaper Elevation="1" Class="pa-3">
                                        <MudText Typo="Typo.subtitle2">@p.Key</MudText>
                                        <MudText Typo="Typo.body2">Type: @p.Type</MudText>
                                        @if (p.Value != null) { <MudText Typo="Typo.body2">Value: @p.Value</MudText> }
                                    </MudPaper>
                                </MudItem>
                            }
                        </MudGrid>
                    }
                </MudStack>
            </MudPaper>
        }
        else {
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.body1" Class="mud-text-secondary">Select a schedule to view details</MudText>
            </MudPaper>
        }
    </MudItem>
</MudGrid>

@code {
    [Parameter] public IReadOnlyList<JobScheduleRes>? JobSchedules { get; set; }
    [Parameter] public Guid JobDefinitionId { get; set; }
    [Parameter, EditorRequired] public IApiClient ApiClient { get; set; } = null!;
    [Parameter, EditorRequired] public string ScheduleRoute { get; set; } = "";

    private JobScheduleRes? _selected;

    protected override void OnParametersSet()
    {
        if (_selected == null || JobSchedules?.All(s => s.Id != _selected.Id) == true)
            _selected = JobSchedules?.FirstOrDefault();
    }

    private async Task ToggleSchedule(JobScheduleRes schedule)
    {
        var patch = new PatchRequestBuilder().WithKey(schedule.Id).SetProperty("Enabled", !schedule.Enabled).Build();
        await ApiClient.PatchAsAsync<PatchRequest, PatchResult<object>>(ScheduleRoute, patch);
        Snackbar.Add($"Schedule {(!schedule.Enabled ? "enabled" : "disabled")}", Severity.Success);
    }
}
