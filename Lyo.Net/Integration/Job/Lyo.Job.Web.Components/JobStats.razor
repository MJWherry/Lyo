@using Microsoft.Extensions.Logging
@inject ILogger<JobStats> Logger

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @if (string.IsNullOrEmpty(StatisticsRoute)) {
        <MudAlert Severity="Severity.Info">Statistics route not configured. Set StatisticsRoute on JobManagement to enable.</MudAlert>

        return;
    }

    @if (_loading) {
        <MudGrid>
            <MudItem xs="12">
                <MudCard>
                    <MudCardContent Class="d-flex justify-center align-center" Style="height: 200px;">
                        <MudProgressCircular Color="Color.Primary" Indeterminate/>
                        <MudText Class="ml-3">Loading statistics...</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        return;
    }

    <!-- Summary row -->
    <MudCard Class="mb-4">
        <MudCardContent>
            <MudGrid Spacing="2" Justify="Justify.SpaceBetween">
                <MudItem xs="6" sm="3">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Work" Color="Color.Primary" Class="mr-2"/>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total Jobs</MudText>
                            <MudText Typo="Typo.h6">@_filtered.Count()</MudText>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Info" Class="mr-2"/>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total Runs</MudText>
                            <MudText Typo="Typo.h6">@_filtered.Sum(j => j.TotalRuns)</MudText>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Class="mr-2"/>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Success Rate</MudText>
                            <MudText Typo="Typo.h6">@($"{OverallSuccessRate():F1}%")</MudText>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Timer" Color="Color.Warning" Class="mr-2"/>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Avg Runtime</MudText>
                            <MudText Typo="Typo.h6">@AverageRuntime()</MudText>
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    <!-- Charts -->
    @if (_stats.Any()) {
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Result Distribution</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (ResultData().Sum() > 0) {
                            <MudChart T="double" ChartType="ChartType.Pie"
                                      ChartOptions="@_pieOptions"
                                      InputData="@ResultData()"
                                      InputLabels="@ResultLabels"
                                      Width="100%" Height="350px"/>
                        }
                        else {
                            <div class="d-flex justify-center align-center" style="height:350px;">
                                <MudText Color="Color.Secondary">No data</MudText>
                            </div>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Runtime (seconds)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudChart ChartType="ChartType.Bar"
                                  ChartOptions="@_barOptions"
                                  ChartSeries="@RuntimeSeries()"
                                  XAxisLabels="@JobLabels()"
                                  Width="100%" Height="350px"/>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    }

    <!-- Detail table -->
    <MudCard Class="mt-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Detailed Statistics</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudDataGrid Items="@_filtered" Striped Hover Filterable SortMode="SortMode.Multiple" Pagination PageSize="15">
                <Columns>
                    <PropertyColumn Property="x => x.JobName" Title="Job"/>
                    <PropertyColumn Property="x => x.TotalRuns" Title="Runs"/>
                    <PropertyColumn Property="x => x.SuccessCount" Title="Success"/>
                    <PropertyColumn Property="x => x.FailureCount" Title="Failures"/>
                    <TemplateColumn Title="Success Rate">
                        <CellTemplate>
                            <div class="d-flex align-center">
                                <MudProgressLinear Color="Color.Success" Value="@((double)(context.Item.SuccessRatePercent ?? 0))" Class="mr-2" Style="width:60px;"/>
                                <MudText Typo="Typo.body2">@($"{context.Item.SuccessRatePercent ?? 0:F1}%")</MudText>
                            </div>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Avg Runtime">
                        <CellTemplate>
                            @if (context.Item.AvgRunTimeMs.HasValue) {
                                <MudText>@TimeSpan.FromMilliseconds(context.Item.AvgRunTimeMs.Value).ToString(@"mm\:ss")</MudText>
                            }
                            else {
                                <MudText>-</MudText>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Last Run">
                        <CellTemplate>
                            <div>
                                <MudText Typo="Typo.body2">@context.Item.LastRunResult</MudText>
                                @if (context.Item.LastRunTime.HasValue) {
                                    <MudText Typo="Typo.caption">@context.Item.LastRunTime.Value.ToString("MMM dd HH:mm")</MudText>
                                }
                            </div>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {

    [Parameter][EditorRequired]
    public IApiClient ApiClient { get; set; } = null!;

    [Parameter]
    public string? StatisticsRoute { get; set; }

    private bool _loading;
    private IReadOnlyList<SpJobStatistic> _stats = [];

    private IEnumerable<SpJobStatistic> _filtered => _stats;

    private static readonly string[] ResultLabels = ["Success", "Failure", "Warn", "Partial", "Cancelled", "Skipped", "Timeout", "Unknown"];

    private readonly ChartOptions _pieOptions = new() { ChartPalette = ["#4CAF50", "#F44336", "#FF9800", "#2196F3", "#9C27B0", "#607D8B", "#795548", "#FF5722"] };
    private readonly ChartOptions _barOptions = new() { ChartPalette = ["#2196F3", "#4CAF50", "#FF9800"] };

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(StatisticsRoute))
            return;

        _loading = true;
        try {
            _stats = await ApiClient.GetAsAsync<IReadOnlyList<SpJobStatistic>>(StatisticsRoute) ?? [];
        }
        catch (Exception ex) {
            Logger.LogError(ex, "Failed to load job statistics");
        }
        finally {
            _loading = false;
        }
    }

    private double[] ResultData()
    {
        var s = _filtered.ToList();
        return [s.Sum(j => j.SuccessCount), s.Sum(j => j.FailureCount), s.Sum(j => j.SuccessWithWarningsCount), s.Sum(j => j.PartialSuccessCount), s.Sum(j => j.CancelledCount), s.Sum(j => j.SkippedCount), s.Sum(j => j.TimeoutCount), s.Sum(j => j.UnknownCount)];
    }

    private string[] JobLabels() => _filtered.Select(j => j.JobName.Length > 15 ? j.JobName[..12] + "..." : j.JobName).ToArray();

    private List<ChartSeries<double>> RuntimeSeries() => [new() { Name = "Average", Data = _filtered.Select(j => (j.AvgRunTimeMs ?? 0) / 1000).ToArray() }, new() { Name = "Min", Data = _filtered.Select(j => (j.MinRunTimeMs ?? 0) / 1000).ToArray() }, new() { Name = "Max", Data = _filtered.Select(j => (j.MaxRunTimeMs ?? 0) / 1000).ToArray() }];

    private double OverallSuccessRate()
    {
        var total = _filtered.Sum(j => j.TotalRuns);
        return total > 0 ? (double)_filtered.Sum(j => j.SuccessCount) / total * 100 : 0;
    }

    private string AverageRuntime()
    {
        var withData = _filtered.Where(j => j.AvgRunTimeMs.HasValue).ToList();
        if (!withData.Any())
            return "-";

        return TimeSpan.FromMilliseconds(withData.Average(j => j.AvgRunTimeMs!.Value)).ToString(@"mm\:ss");
    }

}
