@inject ISnackbar Snackbar
@inject IDialogService DialogService

<LyoDataGridProjected @ref="_dataGrid"
                      ApiClient="ApiClient"
                      GridKey="JobDefinitionGrid"
                      Route="@_definitionRoute"
                      KeySelector="@GetKey"
                      FilterPropertyDefinitions="@_propertyDefinitions"
                      BeforeQuery="@(q => q.AddIncludes("JobSchedules.JobScheduleParameters", "JobTriggerTriggersJobDefinitions", "JobParameters"))"
                      Features="@LyoDataGridFeatureFlags.All">
    <LeftControls>
        <MudButton OnClick="@OpenCreateRunDialog"
                   StartIcon="@Icons.Material.Filled.Add"
                   Size="Size.Small"
                   Variant="Variant.Outlined"
                   Color="Color.Default">
            Create Job Run
        </MudButton>
    </LeftControls>
    <BulkMenuItems>
        <MudMenuItem OnClick="@(() => BulkToggle(true))">Enable</MudMenuItem>
        <MudMenuItem OnClick="@(() => BulkToggle(false))">Disable</MudMenuItem>
    </BulkMenuItems>
    <Columns>
        <LyoProjectedColumn Field="Id" Title="ID"/>
        <LyoProjectedColumn Field="Name" Title="Name" QuickSearchPropertyName="Name"/>
        <LyoProjectedColumn Field="Description" Title="Description" QuickSearchPropertyName="Description"/>
        <LyoProjectedColumn Field="Type" Title="Type" QuickSearchPropertyName="Type"/>
        <LyoProjectedColumn Field="WorkerType" Title="Worker Type"/>
        <LyoProjectedColumn Field="Enabled" Title="Enabled"/>
        <LyoProjectedColumn Field="JobSchedules.Count" Title="Schedules"/>
        <LyoProjectedColumn Field="JobParameters.Count" Title="Parameters"/>
        <LyoProjectedColumn Field="MaxRetryCount" Title="Max Retries" HiddenByDefault="true"/>
    </Columns>
    <RowMenuControls Context="item">
        <MudMenuItem Icon="@Icons.Material.Filled.Visibility" OnClick="@(() => ViewDefinition(item))">View</MudMenuItem>
        <MudMenuItem Icon="@Icons.Material.Filled.PlayArrow" OnClick="@(() => RunJob(item))">Run</MudMenuItem>
        <MudMenuItem Icon="@Icons.Material.Filled.ToggleOn" OnClick="@(() => ToggleDefinition(item))">Toggle Enabled</MudMenuItem>
    </RowMenuControls>
</LyoDataGridProjected>

@code {

    [Parameter]
    [EditorRequired]
    public IApiClient ApiClient { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public string BaseRoute { get; set; } = "Job";

    private string _definitionRoute => $"{BaseRoute.TrimEnd('/')}/Definition";

    private string _runRoute => $"{BaseRoute.TrimEnd('/')}/Run";

    private string _scheduleRoute => $"{BaseRoute.TrimEnd('/')}/Schedule";

    private string _triggerRoute => $"{BaseRoute.TrimEnd('/')}/Trigger";

    private LyoDataGridProjected? _dataGrid;

    private readonly List<FilterPropertyDefinition> _propertyDefinitions = [new("Name"), new("Type"), new("WorkerType", "Worker Type"), new("Enabled", type: FilterPropertyType.Bool)];

    private static object[] GetKey(object? item)
    {
        var id = ProjectedValueHelper.GetValue(item, "Id");
        return id != null ? [id] : [];
    }

    private async Task<JobDefinitionRes?> FetchDefinition(object? id, string[]? includes = null)
    {
        var req = new QueryReq { Keys = [[id!]], Amount = 1 };
        if (includes != null)
            req.Include.AddRange(includes);

        var res = await ApiClient.PostAsAsync<QueryReq, QueryRes<JobDefinitionRes>>($"{_definitionRoute}/Query", req);
        return res?.Items?.FirstOrDefault();
    }

    private async Task OpenCreateRunDialog()
    {
        var res = await ApiClient.PostAsAsync<QueryReq, QueryRes<JobDefinitionRes>>($"{_definitionRoute}/Query", new() { Amount = 200, Include = ["JobParameters"] });
        var options = new DialogOptions {
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };

        var parameters = new DialogParameters<RunJobDialog> { { d => d.JobDefinitions, res?.Items ?? [] }, { d => d.RunRoute, _runRoute } };
        var dialog = await DialogService.ShowAsync<RunJobDialog>("Create Job Run", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await _dataGrid!.RefreshData();
    }

    private async Task ViewDefinition(object? item)
    {
        if (item == null)
            return;

        var id = ProjectedValueHelper.GetValue(item, "Id");
        if (id == null)
            return;

        var def = await FetchDefinition(id, ["JobSchedules.JobScheduleParameters", "JobTriggerTriggersJobDefinitions", "JobParameters"]);
        if (def == null)
            return;

        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true, CloseButton = true };
        var parameters = new DialogParameters<JobDefinitionView> {
            { d => d.JobDefinition, def },
            { d => d.DefinitionRoute, _definitionRoute },
            { d => d.ScheduleRoute, _scheduleRoute },
            { d => d.TriggerRoute, _triggerRoute }
        };

        var dialog = await DialogService.ShowAsync<JobDefinitionView>("Job Definition", parameters, options);
        var r = await dialog.Result;
        if (r is { Canceled: false })
            await _dataGrid!.RefreshData();
    }

    private async Task RunJob(object? item)
    {
        if (item == null)
            return;

        var id = ProjectedValueHelper.GetValue(item, "Id");
        if (id == null)
            return;

        var def = await FetchDefinition(id, ["JobParameters"]);
        if (def == null)
            return;

        var options = new DialogOptions {
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };

        var parameters = new DialogParameters<RunJobDialog> { { d => d.JobDefinitions, new List<JobDefinitionRes> { def } }, { d => d.SelectedJobDefinition, def }, { d => d.RunRoute, _runRoute } };
        var dialog = await DialogService.ShowAsync<RunJobDialog>("Create Job Run", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await _dataGrid!.RefreshData();
    }

    private async Task ToggleDefinition(object? item)
    {
        if (item == null)
            return;

        var id = ProjectedValueHelper.GetValue(item, "Id");
        var enabledVal = ProjectedValueHelper.GetValue(item, "Enabled");
        if (id == null)
            return;

        var currentEnabled = enabledVal is true || enabledVal?.ToString() == "True";
        var patch = new PatchRequestBuilder().WithKey(id).SetProperty("Enabled", !currentEnabled).Build();
        await ApiClient.PatchAsAsync<PatchRequest, PatchResult<object>>(_definitionRoute, patch);
        Snackbar.Add($"Definition {(!currentEnabled ? "enabled" : "disabled")}", Severity.Success);
        await _dataGrid!.RefreshData();
    }

    private async Task BulkToggle(bool value)
    {
        if (_dataGrid?.SelectedItems is not { Count: > 0 } selected)
            return;

        var ids = selected.Select(i => ProjectedValueHelper.GetValue(i, "Id")).Where(i => i != null).ToList();
        var patch = new PatchRequestBuilder().WithOneOfIdentifier("Id", ids).SetProperty("Enabled", value).AllowMultiple().Build();
        await ApiClient.PatchAsAsync<PatchRequest, PatchBulkResult<object>>($"{_definitionRoute}/Bulk", patch);
        Snackbar.Add($"{(value ? "Enabled" : "Disabled")} {ids.Count} definition(s)", Severity.Success);
        await _dataGrid!.RefreshData();
    }

}
