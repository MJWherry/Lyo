<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>Lyo.Espn.Fantasy.Football</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>Client library for ESPN fantasy football league data, rosters, players, transactions, and communication endpoints.</description>
        <summary>ESPN fantasy football client library</summary>
        <copyright>Copyright © Lyo</copyright>
        <tags>espn fantasy football client api league roster player transactions</tags>
        <repository type="git" url="https://github.com/mjwherry/Lyo"/>
        <dependencies>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Api.Client" version="[1.0.71,)"/>
                            <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Binder" version="[10,)"/>
                <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[10,)"/>
</group>
        </dependencies>
    </metadata>
    <files>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
