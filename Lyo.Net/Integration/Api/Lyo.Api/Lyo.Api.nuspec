<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>Lyo.Api</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>Core API library for building RESTful APIs with Entity Framework Core, caching, and mapping
            support.
        </description>
        <summary>Core API library</summary>
        <readme>README.md</readme>
        <copyright>Copyright © Lyo</copyright>
        <tags>api rest aspnetcore entity-framework caching</tags>
        <repository type="git" url="https://github.com/mjwherry/Lyo"/>
        <dependencies>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Api.Models" version="[1.0.71,)"/>
                <dependency id="Lyo.Cache" version="[1.0.71,)"/>
                <dependency id="Lyo.Csv" version="[1.0.71,)"/>
                <dependency id="Lyo.Diff" version="[1.0.71,)"/>
                <dependency id="Lyo.Formatter" version="[1.0.71,)"/>
                <dependency id="Lyo.Metrics" version="[1.0.71,)"/>
                <dependency id="Lyo.Query" version="[1.0.71,)"/>
                <dependency id="Lyo.Xlsx" version="[1.0.71,)"/>
                <dependency id="Microsoft.AspNetCore.Authorization" version="[10,)"/>
                <dependency id="Microsoft.AspNetCore.Http.Abstractions" version="2.*"/>
                <dependency id="Microsoft.AspNetCore.OpenApi" version="[10,)"/>
                <dependency id="Microsoft.EntityFrameworkCore" version="[10,)"/>
                <dependency id="Microsoft.EntityFrameworkCore.Analyzers" version="[10,)"/>
                <dependency id="Microsoft.EntityFrameworkCore.Relational" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Hosting.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[10.0.1,)"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="README.md" target=""/>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
