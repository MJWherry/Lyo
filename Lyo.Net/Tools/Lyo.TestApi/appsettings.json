{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AwsKeyStore": {
    "AccessKeyId": "replace-me",
    "SecretAccessKey": "replace-me",
    "Region": "replace-me",
    "SecretNamePrefix": "replace-me"
  },
  "S3FileStorageOptions": {
    "BucketName": "replace-me",
    "Region": "replace-me",
    "AccessKeyId": "replace-me",
    "SecretAccessKey": "replace-me",
    "EnableMetrics": true
  },
  "PostgresFileMetadataStore": {
    "ConnectionString": "Host=localhost;Port=5432;Database=postgres;Username=postgres;Password=replace-me",
    "EnableAutoMigrations": false
  },
  "QueryOptions": {
    "CacheQueryResultsAsUtf8Payload": true,
    "EnableSplitQueries": true
  },
  "CacheOptions": {
    "Enabled": true,
    "DefaultExpiration": "00:10:00",
    "EnableMetrics": false,
    "Payload": {
      "AutoCompress": true,
      "AutoCompressMinSizeBytes": 8192
    }
  },
  "ApiClient": {
    "AcceptEncodings": [
      "gzip",
      "deflate",
      "br"
    ],
    "EnableAutoResponseDecompression": true,
    "RequestCompression": "Brotli",
    "RequestCompressionMinBytes": 1024
  }
}
