{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApiClient": {
    "BaseUrl": "http://localhost:5251/",
    "AcceptEncodings": [
      "gzip",
      "deflate",
      "br"
    ],
    "EnableAutoResponseDecompression": true,
    "RequestCompression": "Brotli",
    "RequestCompressionMinBytes": 1024
  },
  "FileStorageWorkbench": {
    "UseTestApiServices": true,
    "AutoRegisterS3Services": false,
    "ApiRoutePrefix": "Workbench/FileStorage",
    "FileStorageServiceKey": "gateway-filestorage",
    "KeyStoreServiceKey": "gateway-filestorage",
    "MetadataStoreKey": "gateway-filestorage-metadata",
    "AwsKeyStoreConfigSection": "AwsKeyStore",
    "S3FileStorageConfigSection": "S3FileStorageOptions",
    "MetadataStoreConfigSection": "PostgresFileMetadataStore"
  },
  "AwsKeyStore": {
    "AccessKeyId": "replace-me",
    "SecretAccessKey": "replace-me",
    "Region": "replace-me",
    "SecretNamePrefix": "replace-me"
  },
  "S3FileStorageOptions": {
    "BucketName": "replace-me",
    "Region": "replace-me",
    "AccessKeyId": "replace-me",
    "SecretAccessKey": "replace-me",
    "EnableMetrics": true
  },
  "PostgresFileMetadataStore": {
    "ConnectionString": "Host=localhost;Port=5432;Database=postgres;Username=postgres;Password=replace-me",
    "EnableAutoMigrations": false
  },
  "AwsTranslationOptions": {
    "AccessKeyId": "replace-me",
    "SecretAccessKey": "replace-me",
    "Region": "replace-me"
  },
  "TypecastClient": {
    "ApiBaseUrl": "https://typecast.ai",
    "ApiKey": "replace-me"
  },
  "TypecastOptions": {
    "DefaultModel": "ssfm-v3.0"
  },
  "EmailServiceOptions": {
    "Host": "replace-me",
    "Port": 587,
    "UseSsl": true,
    "DefaultFromAddress": "replace-me",
    "DefaultFromName": "replace-me",
    "Username": "replace-me",
    "Password": "replace-me",
    "EnableMetrics": true
  },
  "TwilioOptions": {
    "AccountSid": "replace-me",
    "AuthToken": "replace-me",
    "DefaultFromPhoneNumber": "replace-me",
    "EnableMetrics": true
  },
  "RabbitMqOptions": {
    "Host": "replace-me",
    "Port": 5672,
    "Username": "replace-me",
    "Password": "replace-me",
    "VirtualHost": "/",
    "AdminUrl": "http://localhost:15672",
    "EnableMetrics": true
  },
  "WebRenderOptions": {
    "EnableMetrics": true
  },
  "CacheOptions": {
    "Enabled": true,
    "EnableMetrics": true
  }
}
