@using System.Globalization
@using Lyo.Comic
@using Lyo.Comic.Api.Models.Response
@using Lyo.Comic.Enums
@using Lyo.Comic.Web.Components
@using Lyo.Common.Extensions
@using Constants = Constants
@inherits AuthorizedPage
@inject IComicApiClient ComicApi
@inject NavigationManager Navigator
@attribute [Route("/" + Constants.Page.ComicsSeries + "/{SeriesId:guid}")]

@if (_loadFailed) {
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
        <MudAlert Severity="Severity.Warning" Class="mb-4">Series not found.</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/{Constants.Page.Comics}")">
            Back to comics
        </MudButton>
    </MudContainer>
}
else if (!_ready || _series is null) {
    <MudProgressLinear Indeterminate="true"/>
}
else {
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-6 comic-series-page">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           title="Back to search"
                           OnClick="BackToComicsAsync"/>
            <MudText Typo="Typo.h5">@_series.Title</MudText>
        </MudStack>

        <MudPaper Class="pa-4 mb-4 comic-series-page__hero" Elevation="1">
            <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Start">
                <div class="comic-series-page__hero-cover">
                    @if (!string.IsNullOrWhiteSpace(_coverUrl)) {
                        <img src="@_coverUrl" alt="" class="comic-series-page__hero-img"/>
                    }
                    else {
                        <div class="comic-series-page__hero-placeholder">
                            <MudIcon Icon="@Icons.Material.Filled.AutoStories" Style="font-size: 4rem; opacity: 0.35;"/>
                        </div>
                    }
                </div>
                <MudStack Spacing="1" Class="flex-grow-1" Style="min-width:0;">
                    @if (!string.IsNullOrWhiteSpace(_series.Author)) {
                        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">@_series.Author</MudText>
                    }
                    @if (!string.IsNullOrWhiteSpace(_heroDescription)) {
                        <MudText Typo="Typo.body2" Class="comic-series-page__desc">@_heroDescription</MudText>
                    }
                </MudStack>
            </MudStack>
        </MudPaper>

        <MudStack Row="true"
                  AlignItems="AlignItems.Center"
                  Justify="Justify.FlexEnd"
                  Spacing="2"
                  Class="mb-3 flex-wrap">
            <MudText Typo="Typo.caption" Color="Color.Secondary">View</MudText>
            <MudButtonGroup OverrideStyles="false" Variant="Variant.Outlined" Size="Size.Small">
                <MudButton OnClick="@(() => _viewMode = ComicBrowseViewMode.GridLarge)"
                           Variant="@(_viewMode == ComicBrowseViewMode.GridLarge ? Variant.Filled : Variant.Outlined)"
                           Color="@(_viewMode == ComicBrowseViewMode.GridLarge ? Color.Primary : Color.Default)">Grid L</MudButton>
                <MudButton OnClick="@(() => _viewMode = ComicBrowseViewMode.GridSmall)"
                           Variant="@(_viewMode == ComicBrowseViewMode.GridSmall ? Variant.Filled : Variant.Outlined)"
                           Color="@(_viewMode == ComicBrowseViewMode.GridSmall ? Color.Primary : Color.Default)">Grid S</MudButton>
                <MudButton OnClick="@(() => _viewMode = ComicBrowseViewMode.ListNoImage)"
                           Variant="@(_viewMode == ComicBrowseViewMode.ListNoImage ? Variant.Filled : Variant.Outlined)"
                           Color="@(_viewMode == ComicBrowseViewMode.ListNoImage ? Color.Primary : Color.Default)">List</MudButton>
                <MudButton OnClick="@(() => _viewMode = ComicBrowseViewMode.ListLine)"
                           Variant="@(_viewMode == ComicBrowseViewMode.ListLine ? Variant.Filled : Variant.Outlined)"
                           Color="@(_viewMode == ComicBrowseViewMode.ListLine ? Color.Primary : Color.Default)">Lines</MudButton>
            </MudButtonGroup>
        </MudStack>

        @if (_volumes.Count > 0) {
            <MudText Typo="Typo.h6" Class="mb-2">Volumes</MudText>
            <ComicBrowseResults ViewMode="_viewMode" Class="mb-6">
                @foreach (var v in _volumes) {
                    <ComicBrowseCard Title="@VolumeTitle(v)"
                                     Subtitle="@VolumeSubtitle(v)"
                                     CoverImageUrl="@ComicCoverUrls.Resolve(v.CoverImageRef)"
                                     TypeBadge="@TypeBadge"
                                     LanguageLine="@_series.Language"
                                     PageCount="@TotalPagesInVolume(v.Id)"
                                     Tags="@v.Tags"
                                     ViewMode="_viewMode"
                                     ShowReadActions="false"
                                     OnCoverClick="@(() => GoReaderVolumeCoverAsync(v.Id))"
                                     OnPrimaryClick="@(() => GoVolumeAsync(v.Id))"/>
                }
            </ComicBrowseResults>
        }

        @if (_orphanChapters.Count > 0) {
            <MudText Typo="Typo.h6" Class="mb-2">Chapters</MudText>
            <ComicBrowseResults ViewMode="_viewMode">
                @foreach (var ch in _orphanChapters) {
                    <ComicBrowseCard Title="@ChapterTitle(ch)"
                                     Subtitle="@ch.Language"
                                     Description="@ch.Title"
                                     CoverImageUrl="@ComicCoverUrls.Resolve(ch.CoverImageRef)"
                                     TypeBadge="@TypeBadge"
                                     LanguageLine="@ch.Language"
                                     PageCount="@ch.PageCount"
                                     Tags="@EmptyTags"
                                     ViewMode="_viewMode"
                                     ShowReadActions="false"
                                     OnCoverClick="@(() => GoReaderChapterAsync(ch.Id))"
                                     OnPrimaryClick="@(() => GoReaderChapterAsync(ch.Id))"/>
                }
            </ComicBrowseResults>
        }
    </MudContainer>
}

@code {

    [Parameter]
    public Guid SeriesId { get; set; }

    protected override string PageName { get; set; } = "Series";

    private const string ComicApiPrefix = "api/comic";

    private ComicSeries? _series;
    private IReadOnlyList<ComicVolumeRes> _volumes = [];
    private IReadOnlyList<ComicChapter> _chapters = [];
    private bool _loadFailed;
    private bool _ready;
    private string? _coverUrl;
    private string? _heroDescription;
    private ComicBrowseViewMode _viewMode = ComicBrowseViewMode.GridSmall;

    private static readonly IReadOnlyList<string> EmptyTags = [];

    private Task BackToComicsAsync()
    {
        Navigator.NavigateTo($"/{Constants.Page.Comics}");
        return Task.CompletedTask;
    }

    private IReadOnlyList<ComicChapter> _orphanChapters
        => _chapters.Where(c => c.VolumeId is null).OrderBy(c => c.ChapterNumber).ToList();

    private string? TypeBadge
        => _series is { ComicType: var t } && t != ComicType.Unknown ? t.ToString() : null;

    protected override async Task OnParametersSetAsync()
    {
        if (SeriesId == Guid.Empty)
            return;

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _ready = false;
        _loadFailed = false;
        _series = null;

        var res = await ComicApi.GetAsAsync<ComicSeriesRes>($"{ComicApiPrefix}/series/{SeriesId}");
        if (res is null) {
            _loadFailed = true;
            return;
        }

        var series = ToSeries(res);
        var volumes = await ComicApi.GetAsAsync<ComicVolumeRes[]>($"{ComicApiPrefix}/series/{SeriesId}/volumes") ?? [];
        var chapters = await ComicApi.GetAsAsync<IReadOnlyList<ComicChapter>>($"{ComicApiPrefix}/series/{SeriesId}/chapters") ?? [];

        _series = series;
        PageName = string.IsNullOrWhiteSpace(series.Title) ? "Series" : series.Title;
        _coverUrl = ComicCoverUrls.Resolve(series.CoverImageRef);
        _heroDescription = series.Description?.Truncated(end: 400);
        _volumes = volumes;
        _chapters = chapters;
        _ready = true;
    }

    private static string VolumeTitle(ComicVolumeRes v)
    {
        if (v.VolumeNumber.HasValue)
            return $"Vol. {v.VolumeNumber:G}" + (string.IsNullOrWhiteSpace(v.Title) ? "" : $" — {v.Title}");

        return string.IsNullOrWhiteSpace(v.Title) ? "Volume" : v.Title;
    }

    private static string? VolumeSubtitle(ComicVolumeRes v)
        => v.PublishedDate?.ToString("d", CultureInfo.CurrentCulture);

    private int? TotalPagesInVolume(Guid volumeId)
    {
        var sum = 0;
        var any = false;
        foreach (var c in _chapters.Where(c => c.VolumeId == volumeId)) {
            if (c.PageCount is int p && p > 0) {
                sum += p;
                any = true;
            }
        }

        return any ? sum : null;
    }

    private static string ChapterTitle(ComicChapter ch)
        => $"Ch. {ch.ChapterNumber:G}" + (string.IsNullOrWhiteSpace(ch.Title) ? "" : $" — {ch.Title}");

    private Task GoVolumeAsync(Guid volumeId)
    {
        Navigator.NavigateTo($"/{Constants.Page.ComicsVolume}/{volumeId}");
        return Task.CompletedTask;
    }

    private Task GoReaderChapterAsync(Guid chapterId)
    {
        Navigator.NavigateTo(ReaderUrl(SeriesId, chapterId, 1));
        return Task.CompletedTask;
    }

    private Task GoReaderVolumeCoverAsync(Guid volumeId)
    {
        var ch = FirstChapterInVolume(volumeId);
        if (ch is null)
            return Task.CompletedTask;

        Navigator.NavigateTo(ReaderUrl(SeriesId, ch.Id, 1));
        return Task.CompletedTask;
    }

    private ComicChapter? FirstChapterInVolume(Guid volumeId)
        => _chapters.Where(c => c.VolumeId == volumeId).OrderBy(c => c.ChapterNumber).FirstOrDefault();

    private string ReaderUrl(Guid seriesId, Guid chapterId, int page)
        => $"/{Constants.Page.ComicsRead}/{seriesId}?chapter={chapterId}&page={page.ToString(CultureInfo.InvariantCulture)}";

    private static ComicSeries ToSeries(ComicSeriesRes r)
        => new() {
            Id = r.Id,
            Title = r.Title,
            Slug = r.Slug,
            ComicType = r.ComicType,
            Status = r.Status,
            Description = r.Description,
            Language = r.Language,
            PublishedYear = r.PublishedYear,
            Author = r.Author,
            Artist = r.Artist,
            Publisher = r.Publisher,
            Source = r.Source,
            CoverImageRef = r.CoverImageRef,
            Demographic = r.Demographic,
            CreatedTimestamp = r.CreatedTimestamp,
            UpdatedTimestamp = r.UpdatedTimestamp,
            AlternateTitles = r.AlternateTitles.Select(a =>
                new ComicAlternateTitle { Id = a.Id, Title = a.Title, Language = a.Language }).ToList(),
            Tags = r.Tags.Count > 0 ? r.Tags.ToList() : []
        };

}
