@namespace Lyo.Comic.Web.Components

<div class="comic-search">
    <MudPaper Class="pa-4 mb-4" Elevation="0">
        <MudStack Spacing="3">
            <div>
                <MudText Typo="Typo.h5">Browse Comics</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Search by title, type, status, or language.
                </MudText>
            </div>

            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField @bind-Value="_titleContains"
                                  Label="Title"
                                  Placeholder="e.g. One Piece, Batman…"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="false"
                                  OnKeyDown="OnTitleKeyDownAsync"
                                  Clearable="true"/>
                </MudItem>

                <MudItem xs="6" sm="3" md="2">
                    <MudSelect T="ComicType?" @bind-Value="_comicType" Label="Type" Clearable="true">
                        @foreach (var t in Enum.GetValues<ComicType>()) {
                            <MudSelectItem T="ComicType?" Value="t">@t.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="6" sm="3" md="2">
                    <MudSelect T="ComicStatus?" @bind-Value="_status" Label="Status" Clearable="true">
                        @foreach (var s in Enum.GetValues<ComicStatus>()) {
                            <MudSelectItem T="ComicStatus?" Value="s">@s.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="6" sm="3" md="2">
                    <MudTextField @bind-Value="_language"
                                  Label="Language"
                                  Placeholder="e.g. ja, en, ko"
                                  Clearable="true"/>
                </MudItem>

                @if (AvailableTags.Count > 0) {
                    <MudItem xs="12" sm="6" md="4">
                        <LyoCheckSelect TValue="string"
                                        Label="Tags"
                                        Placeholder="Any tag"
                                        Items="TagItems"
                                        SelectedValues="_selectedTags"
                                        SelectedValuesChanged="@(v => {
                                                                   _selectedTags = v.ToList();
                                                               })"
                                        Searchable="true"/>
                    </MudItem>
                }

                <MudItem xs="6" sm="3" md="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               OnClick="SearchAsync"
                               Disabled="_busy">
                        @if (_busy) {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                        }
                        Search
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudStack>
    </MudPaper>

    @if (_searched && _results.Count == 0 && !_busy) {
        <MudAlert Severity="Severity.Info" Class="mb-4">No results found. Try a different search.</MudAlert>
    }

    @if (_results.Count > 0) {
        <MudStack Row="true"
                  AlignItems="AlignItems.Center"
                  Justify="Justify.FlexEnd"
                  Spacing="2"
                  Class="comic-search__view-toolbar mb-3 flex-wrap">
            <MudText Typo="Typo.caption" Color="Color.Secondary">View</MudText>
            <MudButtonGroup OverrideStyles="false" Variant="Variant.Outlined" Size="Size.Small">
                <MudButton OnClick="@(() => SetViewMode(ComicBrowseViewMode.GridLarge))"
                           Variant="@(_viewMode == ComicBrowseViewMode.GridLarge ? Variant.Filled : Variant.Outlined)"
                           Color="@(_viewMode == ComicBrowseViewMode.GridLarge ? Color.Primary : Color.Default)">
                    Grid L
                </MudButton>
                <MudButton OnClick="@(() => SetViewMode(ComicBrowseViewMode.GridSmall))"
                           Variant="@(_viewMode == ComicBrowseViewMode.GridSmall ? Variant.Filled : Variant.Outlined)"
                           Color="@(_viewMode == ComicBrowseViewMode.GridSmall ? Color.Primary : Color.Default)">
                    Grid S
                </MudButton>
                <MudButton OnClick="@(() => SetViewMode(ComicBrowseViewMode.ListNoImage))"
                           Variant="@(_viewMode == ComicBrowseViewMode.ListNoImage ? Variant.Filled : Variant.Outlined)"
                           Color="@(_viewMode == ComicBrowseViewMode.ListNoImage ? Color.Primary : Color.Default)">
                    List
                </MudButton>
                <MudButton OnClick="@(() => SetViewMode(ComicBrowseViewMode.ListLine))"
                           Variant="@(_viewMode == ComicBrowseViewMode.ListLine ? Variant.Filled : Variant.Outlined)"
                           Color="@(_viewMode == ComicBrowseViewMode.ListLine ? Color.Primary : Color.Default)">
                    Lines
                </MudButton>
            </MudButtonGroup>
        </MudStack>

        <ComicBrowseResults ViewMode="_viewMode">
            @foreach (var series in _results) {
                <ComicCard Series="series"
                           CoverImageUrl="@ResolveCoverUrl(series)"
                           ViewMode="_viewMode"
                           OnRead="OnReadAsync"
                           OnOpenSeries="OnBrowseAsync"/>
            }
        </ComicBrowseResults>

        @if (_hasMore) {
            <div class="d-flex justify-center mt-4">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           OnClick="LoadMoreAsync"
                           Disabled="_busy">
                    Load more
                </MudButton>
            </div>
        }
    }
</div>
