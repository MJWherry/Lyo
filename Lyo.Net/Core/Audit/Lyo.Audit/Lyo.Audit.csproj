<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>netstandard2.0;net10.0</TargetFrameworks>
        <Description>Audit trail library with AuditChange (entity change tracking) and AuditEvent (events to log). AuditChange has type assembly full name, old values, and changed properties. AuditEvent has event type, timestamp, actor, message, and metadata. Includes IAuditRecorder for pluggable storage.</Description>
        <PackageTags>audit trail change-tracking compliance</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\Lyo.Exceptions\Lyo.Exceptions.csproj"/>
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    </ItemGroup>


    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
