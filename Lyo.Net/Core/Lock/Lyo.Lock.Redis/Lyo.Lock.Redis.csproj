<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>netstandard2.0;net10.0</TargetFrameworks>
        <Description>Redis-based distributed lock implementation for Lyo.Lock. Uses StackExchange.Redis for multi-instance coordination.</Description>
        <PackageTags>lock locking distributed redis mutex</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="[10,)"/>
        <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="[10,)"/>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="[10,)"/>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="[10.0.1,)"/>
        <PackageReference Include="StackExchange.Redis" Version="[2.12,)"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\Lyo.Exceptions\Lyo.Exceptions.csproj"/>
        <ProjectReference Include="..\Lyo.Lock\Lyo.Lock.csproj"/>
    </ItemGroup>


    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
