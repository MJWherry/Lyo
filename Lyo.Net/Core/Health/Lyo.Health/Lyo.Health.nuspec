<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>Lyo.Health</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>Interface for services that report their health. IFileStorageService, ICacheService, IMqService extend IHealth. CheckHealthAsync returns HealthResult with
            status, timings, and metadata.
        </description>
        <summary>Health interface for services</summary>
        <readme>README.md</readme>
        <copyright>Copyright © Lyo</copyright>
        <tags>health healthchecks</tags>
        <repository type="git" url="https://github.com/mjwherry/Lyo"/>
        <dependencies>
            <group targetFramework="netstandard2.0">
                <dependency id="Lyo.Exceptions" version="[1.0.71,)"/>
            </group>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Exceptions" version="[1.0.71,)"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="README.md" target=""/>
        <file src="bin/Release/netstandard2.0/*.dll" target="lib/netstandard2.0"/>
        <file src="bin/Release/netstandard2.0/*.pdb" target="lib/netstandard2.0"/>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
