<span style="display: inline-flex; align-items: center; flex-shrink: 0;">
    @if (Policy is null) {
        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="white-space: nowrap;">FP: —</MudText>
    }
    else {
        var fp = RedactionPolicyFingerprint.ComputeSha256HexPrefix(Policy);
        <MudChip T="string" Text="@fp" Size="Size.Small" Variant="Variant.Outlined" title="@($"Fingerprint: {fp}")"/>
    }
</span>

@code {

    [Parameter]
    public RedactionPolicy? Policy { get; set; }

}
