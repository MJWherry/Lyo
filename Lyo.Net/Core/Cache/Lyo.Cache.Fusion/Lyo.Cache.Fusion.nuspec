<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>Lyo.Cache.Fusion</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>FusionCache implementation for Lyo.Cache with Redis backplane support for distributed caching.</description>
        <summary>FusionCache + Redis cache implementation</summary>
        <copyright>Copyright © Lyo</copyright>
        <tags>cache caching redis fusioncache</tags>
        <repository type="git" url="https://github.com/mjwherry/Lyo"/>
        <dependencies>
            <group targetFramework="netstandard2.0">
                <dependency id="Lyo.Cache" version="[1.0.71,)"/>
                <dependency id="Lyo.Compression" version="[1.0.71,)"/>
                <dependency id="Lyo.Exceptions" version="[1.0.71,)"/>
                <dependency id="Lyo.Metrics" version="[1.0.71,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Binder" version="[10,)"/>
                <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[10.0.1,)"/>
                <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[10.0.1,)"/>
                <dependency id="ZiggyCreatures.FusionCache" version="[2.5,)"/>
                <dependency id="ZiggyCreatures.FusionCache.Backplane.StackExchangeRedis" version="[2.5,)"/>
            </group>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Cache" version="[1.0.71,)"/>
                <dependency id="Lyo.Compression" version="[1.0.71,)"/>
                <dependency id="Lyo.Encryption" version="[1.0.71,)"/>
                <dependency id="Lyo.Exceptions" version="[1.0.71,)"/>
                <dependency id="Lyo.Metrics" version="[1.0.71,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Binder" version="[10,)"/>
                <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[10.0.1,)"/>
                <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[10.0.1,)"/>
                <dependency id="ZiggyCreatures.FusionCache" version="[2.5,)"/>
                <dependency id="ZiggyCreatures.FusionCache.Backplane.StackExchangeRedis" version="[2.5,)"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="bin/Release/netstandard2.0/*.dll" target="lib/netstandard2.0"/>
        <file src="bin/Release/netstandard2.0/*.pdb" target="lib/netstandard2.0"/>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
