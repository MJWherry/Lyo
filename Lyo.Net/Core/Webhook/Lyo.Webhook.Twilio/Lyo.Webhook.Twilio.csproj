<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <RootNamespace>Lyo.Webhook.Twilio</RootNamespace>
        <AssemblyName>Lyo.Webhook.Twilio</AssemblyName>
        <NoWarn>$(NoWarn);SYSLIB0021</NoWarn>
        <Description>Twilio webhook signature validation (X-Twilio-Signature) for use with Lyo.Webhook.</Description>
        <PackageTags>webhook twilio hmac security</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\Lyo.Webhook\Lyo.Webhook.csproj"/>
    </ItemGroup>


    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
