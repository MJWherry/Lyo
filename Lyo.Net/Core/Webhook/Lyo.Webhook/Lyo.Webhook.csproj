<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <RootNamespace>Lyo.Webhook</RootNamespace>
        <AssemblyName>Lyo.Webhook</AssemblyName>
        <NoWarn>$(NoWarn);SYSLIB0021</NoWarn>
        <Description>Abstractions, ASP.NET Core mapping, Lyo.Metrics, and logging for inbound webhooks. Provider-specific verifiers live in separate packages.</Description>
        <PackageTags>webhook hmac security aspnetcore metrics</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\Metrics\Lyo.Metrics\Lyo.Metrics.csproj"/>
    </ItemGroup>


    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
