<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>netstandard2.0;net10.0</TargetFrameworks>
        <Description>F# implementations for arithmetic, algebra, statistics, calculus, physics, signal processing, optimization, and numerical tools used by the Lyo mathematics stack.</Description>
        <PackageTags>mathematics math functions fsharp statistics calculus fft linear-algebra numerics</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Common.fs"/>
        <Compile Include="Arithmetic.fs"/>
        <Compile Include="Algebra.fs"/>
        <Compile Include="Geometry.fs"/>
        <Compile Include="Trigonometry.fs"/>
        <Compile Include="LinearAlgebra.fs"/>
        <Compile Include="Statistics.fs"/>
        <Compile Include="Distributions.fs"/>
        <Compile Include="Physics.fs"/>
        <Compile Include="Calculus.fs"/>
        <Compile Include="Interpolation.fs"/>
        <Compile Include="Financial.fs"/>
        <Compile Include="Signal.fs"/>
        <Compile Include="Transforms.fs"/>
        <Compile Include="Optimization.fs"/>
        <Compile Include="Complex.fs"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Lyo.Mathematics\Lyo.Mathematics.csproj"/>
        <ProjectReference Include="..\..\Scientific\Lyo.Scientific\Lyo.Scientific.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
