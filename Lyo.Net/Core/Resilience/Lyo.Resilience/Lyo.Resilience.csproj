<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>netstandard2.0;net10.0</TargetFrameworks>
        <Description>A thin wrapper around Polly for resilience pipelines with configuration-from-appsettings support and built-in logging.</Description>
        <PackageTags>resilience polly retry circuit-breaker configuration</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\Lyo.Exceptions\Lyo.Exceptions.csproj"/>
        <ProjectReference Include="..\..\Metrics\Lyo.Metrics\Lyo.Metrics.csproj"/>
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="[10,)"/>
        <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="[10,)"/>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="[10,)"/>
        <PackageReference Include="Microsoft.Extensions.Http" Version="[10,)"/>
        <PackageReference Include="Polly" Version="8.*"/>
        <PackageReference Include="Polly.Extensions" Version="8.*"/>
    </ItemGroup>


    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
