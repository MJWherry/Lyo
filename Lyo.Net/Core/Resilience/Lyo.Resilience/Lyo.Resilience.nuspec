<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>Lyo.Resilience</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>A thin wrapper around Polly for resilience pipelines with configuration-from-appsettings support and built-in logging.</description>
        <summary>Polly resilience wrapper with config and logging</summary>
        <readme>README.md</readme>
        <copyright>Copyright © Lyo</copyright>
        <tags>resilience polly retry circuit-breaker configuration</tags>
        <repository type="git" url="https://github.com/mjwherry/Lyo"/>
        <dependencies>
            <group targetFramework="netstandard2.0">
                <dependency id="Lyo.Exceptions" version="[1.0.71,)"/>
                <dependency id="Lyo.Metrics" version="[1.0.71,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Binder" version="[10,)"/>
                <dependency id="Microsoft.Extensions.DependencyInjection" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Http" version="[10,)"/>
                <dependency id="Polly" version="8.*"/>
                <dependency id="Polly.Extensions" version="8.*"/>
            </group>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Exceptions" version="[1.0.71,)"/>
                <dependency id="Lyo.Metrics" version="[1.0.71,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Binder" version="[10,)"/>
                <dependency id="Microsoft.Extensions.DependencyInjection" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Http" version="[10,)"/>
                <dependency id="Polly" version="8.*"/>
                <dependency id="Polly.Extensions" version="8.*"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="README.md" target=""/>
        <file src="bin/Release/netstandard2.0/*.dll" target="lib/netstandard2.0"/>
        <file src="bin/Release/netstandard2.0/*.pdb" target="lib/netstandard2.0"/>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
