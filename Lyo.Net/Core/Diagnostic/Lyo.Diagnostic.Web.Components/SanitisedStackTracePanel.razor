@if (Trace is null) {
    <MudText Typo="Typo.body2" Color="Color.Secondary">No sanitised trace yet.</MudText>
}
else {
    <MudStack Spacing="2">
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
            <MudChip T="string" Text="@($"Fingerprint: {Trace.Fingerprint}")" Size="Size.Small"/>
            <MudChip T="string" Text="@($"Frames: {Trace.Frames.Count}")" Size="Size.Small"/>
            <MudChip T="string" Text="@($"Crash confidence: {Trace.CrashSiteConfidence}")" Size="Size.Small"/>
            @if (Trace.HasRecursion) {
                <MudChip T="string" Text="Recursion" Size="Size.Small" Color="Color.Warning"/>
            }
        </MudStack>
        @if (!string.IsNullOrWhiteSpace(Trace.CrashSite)) {
            <div>
                <MudText Typo="Typo.subtitle2" Class="mb-1">Crash site (sanitised)</MudText>
                <MudText Typo="Typo.body2">@Trace.CrashSite</MudText>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Trace.ExceptionMessage)) {
            <div>
                <MudText Typo="Typo.subtitle2" Class="mb-1">Exception message (sanitised)</MudText>
                <MudPaper Outlined="true" Class="pa-2">
                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@Trace.ExceptionMessage</MudText>
                </MudPaper>
            </div>
        }
        <MudText Typo="Typo.subtitle2">Frames</MudText>
        @if (Trace.Frames.Count == 0) {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No frames.</MudText>
        }
        else {
            <MudSimpleTable Dense="true" Hover="true" Style="overflow:auto; max-height:280px;">
                <thead>
                <tr>
                    <th>Category</th>
                    <th>Method</th>
                    <th>Location</th>
                    <th>Flags</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var f in Trace.Frames) {
                    <tr>
                        <td>@f.Category</td>
                        <td style="font-family: monospace; font-size: 0.85rem;">@f.ShortMethod</td>
                        <td>@(f.LocationSummary ?? "—")</td>
                        <td>
                            @(f.IsAsync ? "async " : "")@(f.IsLambda ? "lambda" : "")@((!f.IsAsync && !f.IsLambda) ? "—" : "")
                        </td>
                    </tr>
                }
                </tbody>
            </MudSimpleTable>
        }
        @if (Trace.InnerExceptions.Count > 0) {
            <MudExpansionPanels MultiExpansion="true">
                @foreach (var inner in Trace.InnerExceptions) {
                    <MudExpansionPanel Text="@($"Inner exception ({inner.Frames.Count} frames)")">
                        <SanitisedStackTracePanel Trace="inner"/>
                    </MudExpansionPanel>
                }
            </MudExpansionPanels>
        }
    </MudStack>
}

@code {
    [Parameter]
    public SanitisedStackTrace? Trace { get; set; }

}
