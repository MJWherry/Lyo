<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>Lyo.FileStorage.Web.Components</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>Reusable Blazor components for file storage workbenches: upload/save, DEK/KEK migration and rotation, metadata grid, keystore tools.</description>
        <summary>File storage Blazor components</summary>
        <copyright>Copyright © Lyo</copyright>
        <tags>blazor components file-storage mudblazor keystore</tags>
        <repository type="git" url="https://github.com/mjwherry/Lyo"/>
        <dependencies>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Api.Client" version="[1.0.71,)"/>
                <dependency id="Lyo.FileMetadataStore" version="[1.0.71,)"/>
                <dependency id="Lyo.FileStorage" version="[1.0.71,)"/>
                <dependency id="Lyo.IO.Temp" version="[1.0.71,)"/>
                <dependency id="Lyo.Keystore" version="[1.0.71,)"/>
                <dependency id="Lyo.Web.Components" version="[1.0.71,)"/>
                <dependency id="MudBlazor" version="[9,)"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
