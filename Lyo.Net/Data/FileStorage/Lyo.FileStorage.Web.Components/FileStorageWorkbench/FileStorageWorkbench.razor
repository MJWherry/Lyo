@namespace Lyo.FileStorage.Web.Components

<CascadingValue Value="this">
    <MudStack Spacing="3">
        <FileStorageWorkbenchHeader Title="@Title" Description="@Description"/>
        <FileStorageRegistrationAlerts FileStorageImplementationName="@FileStorageImplementationName"
                                      FileStorageResolutionDescription="@DescribeFileStorageResolution()"
                                      KeyStoreImplementationName="@KeyStoreImplementationName"
                                      KeyStoreResolutionDescription="@DescribeKeyStoreResolution()"/>
        <MudTabs Rounded="true">
            <MudTabPanel Text="Files">
                <FileStoreFilesTab/>
            </MudTabPanel>
            <MudTabPanel Text="Keys">
                <FileStoreKeysTab/>
            </MudTabPanel>
        </MudTabs>
    </MudStack>
</CascadingValue>
