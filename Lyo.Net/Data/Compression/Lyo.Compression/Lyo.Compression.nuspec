<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>Lyo.Compression</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>A production-ready .NET compression library providing efficient, thread-safe compression with
            support for multiple algorithms (GZip, Brotli, Deflate, ZLib, Snappier, ZstdSharp, LZ4, LZMA, BZip2, XZ), batch operations, and
            atomic file operations.
        </description>
        <summary>Production-ready compression library with multiple algorithms and batch operations</summary>
        <readme>README.md</readme>
        <copyright>Copyright © Lyo</copyright>
        <tags>compression gzip brotli deflate zlib snappy zstd lz4 lzma bzip2 xz</tags>
        <repository type="git" url="https://github.com/your-org/Lyo"/>
        <dependencies>
            <group targetFramework="netstandard2.0">
                <dependency id="EasyCompressor" version="[2.1,)"/>
                <dependency id="EasyCompressor.LZ4" version="[2.1,)"/>
                <dependency id="EasyCompressor.LZMA" version="[2.1,)"/>
                <dependency id="EasyCompressor.Snappier" version="[2.1,)"/>
                <dependency id="EasyCompressor.ZstdSharp" version="[2.1,)"/>
                <dependency id="Joveler.Compression.XZ" version="5.0.2"/>
                <dependency id="Lyo.Common" version="[1.0.71,)"/>
                <dependency id="Lyo.Exceptions" version="[1.0.71,)"/>
                <dependency id="Lyo.Metrics" version="[1.0.71,)"/>
                <dependency id="Lyo.Streams" version="[1.0.71,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Binder" version="[10,)"/>
                <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Options" version="[10,)"/>
                <dependency id="SharpZipLib" version="1.4.2"/>
                <dependency id="System.Text.Json" version="[10,)"/>
            </group>
            <group targetFramework="net10.0">
                <dependency id="EasyCompressor" version="[2.1,)"/>
                <dependency id="EasyCompressor.LZ4" version="[2.1,)"/>
                <dependency id="EasyCompressor.LZMA" version="[2.1,)"/>
                <dependency id="EasyCompressor.Snappier" version="[2.1,)"/>
                <dependency id="EasyCompressor.ZstdSharp" version="[2.1,)"/>
                <dependency id="Joveler.Compression.XZ" version="5.0.2"/>
                <dependency id="Lyo.Common" version="[1.0.71,)"/>
                <dependency id="Lyo.Exceptions" version="[1.0.71,)"/>
                <dependency id="Lyo.Metrics" version="[1.0.71,)"/>
                <dependency id="Lyo.Streams" version="[1.0.71,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Binder" version="[10,)"/>
                <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Options" version="[10,)"/>
                <dependency id="SharpZipLib" version="1.4.2"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="README.md" target=""/>
        <file src="bin/Release/netstandard2.0/*.dll" target="lib/netstandard2.0"/>
        <file src="bin/Release/netstandard2.0/*.pdb" target="lib/netstandard2.0"/>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
