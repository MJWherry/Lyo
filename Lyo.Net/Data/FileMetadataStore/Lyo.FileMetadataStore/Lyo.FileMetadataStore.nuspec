<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>Lyo.FileMetadataStore</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>File store service interface and base implementation for metadata and file tracking.</description>
        <summary>File store service interface</summary>
        <copyright>Copyright © Lyo</copyright>
        <tags>file-store metadata tracking</tags>
        <repository type="git" url="https://github.com/mjwherry/Lyo"/>
        <dependencies>
            <group targetFramework="netstandard2.0">
                <dependency id="Lyo.Common" version="[1.0.71,)"/>
                <dependency id="Lyo.Compression" version="[1.0.71,)"/>
                <dependency id="Lyo.Encryption" version="[1.0.71,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Binder" version="[10,)"/>
                <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Options" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Options.DataAnnotations" version="[10,)"/>
                <dependency id="System.Text.Json" version="[10,)"/>
            </group>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Common" version="[1.0.71,)"/>
                <dependency id="Lyo.Compression" version="[1.0.71,)"/>
                <dependency id="Lyo.Encryption" version="[1.0.71,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Binder" version="[10,)"/>
                <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Options" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Options.DataAnnotations" version="[10,)"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="bin/Release/netstandard2.0/*.dll" target="lib/netstandard2.0"/>
        <file src="bin/Release/netstandard2.0/*.pdb" target="lib/netstandard2.0"/>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
