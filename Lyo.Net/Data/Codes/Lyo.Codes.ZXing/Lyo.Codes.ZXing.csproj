<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <RootNamespace>Lyo.Codes.ZXing</RootNamespace>
        <Description>ZXing-based barcode and QR code image decoding for Lyo - supports Code 128, Code 39, EAN, UPC, ITF, Codabar, PDF 417, Data Matrix, and QR codes.</Description>
        <PackageTags>zxing barcode qrcode decoder reader imagesharp</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="SixLabors.ImageSharp" Version="3.*"/>
        <PackageReference Include="ZXing.Net" Version="0.16.11"/>
        <PackageReference Include="ZXing.Net.Bindings.ImageSharp.V3" Version="0.16.15"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\..\Core\Common\Lyo.Common\Lyo.Common.csproj"/><ProjectReference Include="..\..\..\Core\Result\Lyo.Result\Lyo.Result.csproj" />
    </ItemGroup>

</Project>
