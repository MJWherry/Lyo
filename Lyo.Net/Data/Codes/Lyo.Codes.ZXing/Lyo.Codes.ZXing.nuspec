<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <id>Lyo.Codes.ZXing</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>ZXing-based barcode and QR code image decoding for Lyo - supports Code 128, Code 39, EAN, UPC, ITF, Codabar, PDF 417, Data Matrix, and QR codes.</description>
        <summary>ZXing barcode and QR code image decoder.</summary>
        <copyright>Copyright © Lyo</copyright>
        <tags>zxing barcode qrcode decoder reader imagesharp</tags>
        <dependencies>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Common" version="[1.0.71,)"/>
                <dependency id="SixLabors.ImageSharp" version="[3,)"/>
                <dependency id="ZXing.Net" version="0.16.11"/>
                <dependency id="ZXing.Net.Bindings.ImageSharp.V3" version="0.16.15"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
