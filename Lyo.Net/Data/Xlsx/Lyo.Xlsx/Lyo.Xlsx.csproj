<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>netstandard2.0;net10.0</TargetFrameworks>
        <Description>Excel (XLSX) processing library using ClosedXML and ExcelDataReader for reading and writing Excel files.</Description>
        <PackageTags>xlsx excel closedxml exceldatareader</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="ClosedXML" Version="[0.100,)"/>
        <PackageReference Include="ExcelDataReader" Version="[3.8,)"/>
        <PackageReference Include="ExcelDataReader.DataSet" Version="[3.8,)"/>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="[10,)"/>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="[10,)"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\..\Core\Common\Lyo.Common\Lyo.Common.csproj"/>
        <ProjectReference Include="..\..\..\Core\Lyo.Exceptions\Lyo.Exceptions.csproj"/>
        <ProjectReference Include="..\..\..\Core\Result\Lyo.Result\Lyo.Result.csproj"/>
        <ProjectReference Include="..\Lyo.Xlsx.Models\Lyo.Xlsx.Models.csproj"/>
    </ItemGroup>


    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
