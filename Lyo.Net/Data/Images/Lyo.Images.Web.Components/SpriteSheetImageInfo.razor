<MudPaper Class="pa-4" Outlined="true">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h6">Image info</MudText>
        @if (Metadata == null) {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Select a spritesheet to see format and dimensions.
            </MudText>
        }
        else {
            @* Row 1: format + grid + detected (wide). Row 2: frame width/height only. *@
            <MudGrid Spacing="1">
                <MudItem xs="12" sm="6" md="2">
                    <MudTextField T="string" Label="Format" Value="@Metadata.Format.ToString()" ReadOnly="true" Variant="Variant.Outlined"
                                  Margin="Margin.Dense"/>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudTextField T="string" Label="Grid" Value="@($"{Calculation.RowCount}×{Calculation.ColumnCount}")" ReadOnly="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"/>
                </MudItem>
                <MudItem xs="12" md="8">
                    <MudTextField T="string" Label="Detected frames" Value="@($"{Calculation.IncludedFrames.Count} / {Calculation.Frames.Count}")"
                                  ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                </MudItem>
                <MudItem xs="12" sm="6" md="6">
                    <MudTextField T="string" Label="Width" Value="@($"{Calculation.FrameWidth}px")" ReadOnly="true" Variant="Variant.Outlined"
                                  Margin="Margin.Dense"/>
                </MudItem>
                <MudItem xs="12" sm="6" md="6">
                    <MudTextField T="string" Label="Height" Value="@($"{Calculation.FrameHeight}px")" ReadOnly="true" Variant="Variant.Outlined"
                                  Margin="Margin.Dense"/>
                </MudItem>
            </MudGrid>
        }
    </MudStack>
</MudPaper>

@code {

    [Parameter]
    public ImageMetadata? Metadata { get; set; }

    [Parameter]
    public SpriteSheetCalculation Calculation { get; set; } = null!;

}
