<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <IsPackable>false</IsPackable>
        <PrepareTesseractLinuxNativeLibs>true</PrepareTesseractLinuxNativeLibs>
    </PropertyGroup>

    <ItemGroup>
        <Using Include="Xunit"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="[10,)"/>
        <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="[10,)"/>
        <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="[10,)"/>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="[10,)"/>
        <PackageReference Include="SixLabors.ImageSharp" Version="3.*"/>
        <PackageReference Include="SixLabors.ImageSharp.Drawing" Version="2.*"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="appsettings.Development.json" Condition="Exists('appsettings.Development.json')">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\..\Core\Lyo.Testing\Lyo.Testing.csproj"/>
        <ProjectReference Include="..\Lyo.Images.Ocr.Tesseract\Lyo.Images.Ocr.Tesseract.csproj"/>
    </ItemGroup>

    <ItemGroup>
      <None Remove="appsettings.json" />
      <Content Include="appsettings.json">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
    </ItemGroup>

</Project>
