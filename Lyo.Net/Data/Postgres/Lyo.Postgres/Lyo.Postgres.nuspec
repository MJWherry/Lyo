<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <id>Lyo.Postgres</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>Shared PostgreSQL migration infrastructure for Lyo libraries. Provides IHostedService for running EF Core migrations at application startup.</description>
        <readme>README.md</readme>
        <copyright>Copyright © Lyo</copyright>
        <tags>postgres postgresql entityframework ef migrations</tags>
        <dependencies>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Exceptions" version="[1.0.71,)"/>
                <dependency id="Microsoft.EntityFrameworkCore" version="[10,)"/>
                <dependency id="Microsoft.EntityFrameworkCore.Relational" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Hosting.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Options" version="[10,)"/>
                <dependency id="Npgsql.EntityFrameworkCore.PostgreSQL" version="[10,)"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="README.md" target=""/>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
