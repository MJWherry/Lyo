<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <id>Lyo.QRCode</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>QR code generation for Lyo: includes an in-library ISO/IEC 18004 encoder (PNG/SVG via BuiltInQRCodeService) plus abstractions. Optional Lyo.QRCode.QRCoder adds
            JPEG/Bitmap (Windows) and QRCoder-based rendering.
        </description>
        <summary>QR code generation with built-in PNG/SVG output, service abstractions, and optional QRCoder-backed implementation.
        </summary>
        <readme>README.md</readme>
        <copyright>Copyright © Lyo</copyright>
        <tags>qrcode qr code generator barcode abstraction</tags>
        <dependencies>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Codes.ZXing" version="[1.0.71,)"/>
                <dependency id="Lyo.Common" version="[1.0.71,)"/>
                <dependency id="Lyo.Exceptions" version="[1.0.71,)"/>
                <dependency id="Lyo.Images" version="[1.0.71,)"/>
                <dependency id="Lyo.Metrics" version="[1.0.71,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Configuration.Binder" version="[10,)"/>
                <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[10,)"/>
                <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[10,)"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="README.md" target=""/>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
