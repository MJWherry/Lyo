@using Lyo.Pdf.Models
@using Lyo.Web.Components.ChipInput
@namespace Lyo.Pdf.Web.Components.PdfAnnotator

<MudStack Spacing="2">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.subtitle1">@(ResultPhase ? "Saved extraction results" : "Live template regions")</MudText>
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@($"{Rows.Count} region(s)")</MudChip>
    </MudStack>

    <MudText Typo="Typo.caption" Color="Color.Secondary">
        Use each region's bounding box with paragraph, key/value, or table extraction.
    </MudText>

    @if (Rows.Count == 0) {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No regions yet.</MudText>
    }
    else {
        <MudExpansionPanels MultiExpansion="true" Elevation="0" Outlined="true" Dense="true">
            @foreach (var row in Rows) {
                <MudExpansionPanel @key="row.Key" Expanded="true">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudText Typo="Typo.subtitle2">@row.Key</MudText>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">
                                    @GetExtractionSummary(row)
                                </MudChip>
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@row.BoundingBoxSummary</MudText>
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Spacing="2" Class="pt-2">
                            @* Row 1: Type (narrow), Tolerance, [Columns], Apply *@
                            <MudGrid Spacing="2">
                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect T="PdfAnnotationExtractionType"
                                               Label="Type"
                                               Margin="Margin.Dense"
                                               Class="lyo-pdf-extract-type"
                                               Value="@row.ExtractionType"
                                               ValueChanged="value => SetExtractionType(row, value)">
                                        <MudSelectItem Value="@PdfAnnotationExtractionType.BoundingBoxText">Paragraph</MudSelectItem>
                                        <MudSelectItem Value="@PdfAnnotationExtractionType.KeyValue">Key / value</MudSelectItem>
                                        <MudSelectItem Value="@PdfAnnotationExtractionType.Table">Table</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="@(row.ExtractionType is PdfAnnotationExtractionType.Table ? 3 : 2)">
                                    <MudNumericField T="double"
                                                     Label="Tolerance"
                                                     Margin="Margin.Dense"
                                                     Min="0"
                                                     Step="0.5"
                                                     Value="@row.YTolerance"
                                                     ValueChanged="value => SetYTolerance(row, value)"/>
                                </MudItem>
                                @if (row.ExtractionType is PdfAnnotationExtractionType.BoundingBoxText or PdfAnnotationExtractionType.KeyValue) {
                                    <MudItem xs="12" sm="6" md="2">
                                        <MudNumericField T="int"
                                                         Label="Columns"
                                                         Margin="Margin.Dense"
                                                         Min="1"
                                                         Max="24"
                                                         Value="@row.ColumnCount"
                                                         ValueChanged="value => SetColumnCount(row, value)"/>
                                    </MudItem>
                                }
                                <MudItem xs="12" md="@(row.ExtractionType is PdfAnnotationExtractionType.Table ? 6 : 5)" Class="d-flex align-center justify-end">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               FullWidth="false"
                                               Class="lyo-pdf-apply-btn"
                                               OnClick="@(() => OnApply.InvokeAsync(row))">
                                        Apply
                                    </MudButton>
                                </MudItem>
                            </MudGrid>

                            @* Row 2: Infer (+ key/value layout on same row for Key/Value) *@
                            @if (row.ExtractionType is PdfAnnotationExtractionType.KeyValue or PdfAnnotationExtractionType.Table) {
                                <MudStack Row="true"
                                          AlignItems="AlignItems.Center"
                                          Spacing="2"
                                          Wrap="Wrap.Wrap"
                                          Justify="Justify.SpaceBetween"
                                          Class="mb-1">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Infer from</MudText>
                                        <MudCheckBox T="bool"
                                                     Label="Bold"
                                                     Dense="true"
                                                     Value="@((row.InferFormattingFlags & PdfInferFormattingFlags.Bold) != 0)"
                                                     ValueChanged="v => SetInferBold(row, v)"/>
                                        <MudCheckBox T="bool"
                                                     Label="Punctuation"
                                                     Dense="true"
                                                     Value="@((row.InferFormattingFlags & PdfInferFormattingFlags.Semicolon) != 0)"
                                                     ValueChanged="v => SetInferSemicolon(row, v)"/>
                                        <MudCheckBox T="bool"
                                                     Label="Underline"
                                                     Dense="true"
                                                     Value="@((row.InferFormattingFlags & PdfInferFormattingFlags.Underline) != 0)"
                                                     ValueChanged="v => SetInferUnderline(row, v)"/>
                                    </MudStack>
                                    @if (row.ExtractionType == PdfAnnotationExtractionType.KeyValue) {
                                        <MudButtonGroup OverrideStyles="false"
                                                        Variant="Variant.Outlined"
                                                        Size="Size.Small"
                                                        Class="kv-layout-toggle">
                                            <MudButton OnClick="@(() => SetKeyValueLayout(row, PdfKeyValueLayout.Horizontal))"
                                                       Variant="@(row.KeyValueLayout == PdfKeyValueLayout.Horizontal ? Variant.Filled : Variant.Outlined)"
                                                       Color="@(row.KeyValueLayout == PdfKeyValueLayout.Horizontal ? Color.Primary : Color.Default)">
                                                Horizontal
                                            </MudButton>
                                            <MudButton OnClick="@(() => SetKeyValueLayout(row, PdfKeyValueLayout.Vertical))"
                                                       Variant="@(row.KeyValueLayout == PdfKeyValueLayout.Vertical ? Variant.Filled : Variant.Outlined)"
                                                       Color="@(row.KeyValueLayout == PdfKeyValueLayout.Vertical ? Color.Primary : Color.Default)">
                                                Vertical
                                            </MudButton>
                                        </MudButtonGroup>
                                    }
                                </MudStack>
                            }

                            @* Row 3: Delimiter — only when Punctuation is on *@
                            @if ((row.InferFormattingFlags & PdfInferFormattingFlags.Semicolon) != 0
                                 && (row.ExtractionType is PdfAnnotationExtractionType.KeyValue or PdfAnnotationExtractionType.Table)) {
                                <MudStack Spacing="1" Class="mb-1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Delimiter characters (order = try first)</MudText>
                                    <MudStack Row="true"
                                              Spacing="2"
                                              Wrap="Wrap.Wrap"
                                              AlignItems="AlignItems.Center"
                                              Class="lyo-pdf-delimiter-controls">
                                        <MudSelect T="string"
                                                   MultiSelection="true"
                                                   Dense="true"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Class="lyo-pdf-delimiter-select"
                                                   MaxHeight="320"
                                                   Label="Characters"
                                                   SelectedValues="@GetDelimiterSelectedValues(row)"
                                                   SelectedValuesChanged="@(values => SetDelimiterSelectedValues(row, values))"
                                                   MultiSelectionTextFunc="@DelimiterSelectSummary">
                                            @foreach (var opt in KvDelimiterSelectOptions) {
                                                <MudSelectItem Value="@opt.Value">@opt.Label</MudSelectItem>
                                            }
                                            @foreach (var c in GetExtraDelimiterChars(row)) {
                                                <MudSelectItem Value="@(c.ToString())">@($"Other ‘{c}’")</MudSelectItem>
                                            }
                                        </MudSelect>
                                        <MudTextField T="string"
                                                      Margin="Margin.Dense"
                                                      Variant="Variant.Outlined"
                                                      Class="lyo-pdf-delimiter-other"
                                                      Label="Other"
                                                      Placeholder="+"
                                                      MaxLength="4"
                                                      Value="@GetCustomDelimiterDraft(row.Key)"
                                                      ValueChanged="@(v => SetCustomDelimiterDraft(row, v))"
                                                      Immediate="true"/>
                                    </MudStack>
                                </MudStack>
                            }

                            @if (row.ExtractionType == PdfAnnotationExtractionType.KeyValue) {
                                <MudText Typo="Typo.subtitle2" Class="mb-1">Known keys</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                    Leave empty to infer labels using the options above (bold vs punctuation-terminated lines).
                                </MudText>
                                <div>
                                    <LyoChipInput Values="@row.KnownKeys"
                                                  ValuesChanged="values => SetKnownKeys(row, values)"
                                                  Placeholder="Type a key and press Enter (optional)"/>
                                </div>
                            }
                            else if (row.ExtractionType == PdfAnnotationExtractionType.Table) {
                                <div>
                                    <MudText Typo="Typo.subtitle2" Class="mb-1">Table headers</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                        Leave empty to infer headers using the options above (bold row vs delimiter-separated text).
                                    </MudText>
                                    <LyoChipInput Values="@row.TableHeaders"
                                                  ValuesChanged="values => SetTableHeaders(row, values)"
                                                  SelectableChips="true"
                                                  SingleSelection="true"
                                                  SelectedValues="@GetTableKeySelectedChips(row)"
                                                  SelectedValuesChanged="sel => SetTableKeyChipSelection(row, sel)"
                                                  Placeholder="Type a header and press Enter (optional)"/>
                                    <MudTextField T="string"
                                                  Label="Row key column (optional)"
                                                  Margin="Margin.Dense"
                                                  HelperText="Defaults to the first column. Only this header starts a new row; continuation lines merge into that row."
                                                  Value="@row.TableKeyColumnLabel"
                                                  ValueChanged="v => SetTableKeyColumn(row, v)"/>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">Row key defaults to the first column. Click a header chip to change it, use the field, or prefix a header with <code>*</code>.</MudText>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(row.ErrorMessage)) {
                                <MudAlert Severity="Severity.Warning" Dense="true">@row.ErrorMessage</MudAlert>
                            }

                            @if (row.ExtractionType == PdfAnnotationExtractionType.KeyValue && row.KeyValuePairs is { Count: > 0 }) {
                                <MudSimpleTable Dense="true" Striped="true">
                                    <thead>
                                    <tr>
                                        <th>Key</th>
                                        <th>Value</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var pair in row.KeyValuePairs) {
                                        <tr>
                                            <td>@pair.Key</td>
                                            <td style="white-space:pre-wrap;word-break:break-word;">@(pair.Value ?? "—")</td>
                                        </tr>
                                    }
                                    </tbody>
                                </MudSimpleTable>
                            }
                            else if (row.ExtractionType == PdfAnnotationExtractionType.Table && row.TableRows is { Count: > 0 }) {
                                var headers = GetTableHeaders(row.TableRows);
                                <MudSimpleTable Dense="true" Striped="true" Bordered="true" Style="overflow-x:auto;">
                                    <thead>
                                    <tr>
                                        @foreach (var header in headers) {
                                            <th>@header</th>
                                        }
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var tableRow in row.TableRows) {
                                        <tr>
                                            @foreach (var header in headers) {
                                                <td style="white-space:pre-wrap;word-break:break-word;">@(tableRow.TryGetValue(header, out var value) ? value : "—")</td>
                                            }
                                        </tr>
                                    }
                                    </tbody>
                                </MudSimpleTable>
                            }
                            else if (row.ExtractionType == PdfAnnotationExtractionType.BoundingBoxText && row.ColumnTexts is { Count: > 1 }) {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Result (per column)</MudText>

                                <MudGrid Spacing="2" Class="mt-1">
                                    @for (var i = 0; i < row.ColumnTexts.Count; i++) {
                                        var colIdx = i;
                                        <MudItem xs="12" sm="6" md="@(12 / row.ColumnTexts.Count)">
                                            <MudPaper Class="pa-2" Outlined="true">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Column @(colIdx + 1)</MudText>
                                                <MudText Typo="Typo.body2" Style="white-space:pre-wrap;word-break:break-word;">
                                                    @(string.IsNullOrWhiteSpace(row.ColumnTexts[colIdx]) ? "—" : row.ColumnTexts[colIdx])
                                                </MudText>
                                            </MudPaper>
                                        </MudItem>
                                    }
                                </MudGrid>
                            }
                            else {
                                <MudPaper Class="pa-3" Outlined="true">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Result</MudText>
                                    <MudText Typo="Typo.body2" Style="white-space:pre-wrap;word-break:break-word;">
                                        @(string.IsNullOrWhiteSpace(row.ExtractedText) ? "—" : row.ExtractedText)
                                    </MudText>
                                </MudPaper>
                            }
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    }
</MudStack>

<style>
    .lyo-pdf-extract-type {
        max-width: 11rem;
    }

    .lyo-pdf-apply-btn {
        min-width: 6.5rem;
    }

    .lyo-pdf-delimiter-controls {
        align-items: center;
    }

    .lyo-pdf-delimiter-select {
        min-width: 12rem;
        max-width: 20rem;
        flex: 1 1 12rem;
    }

    .lyo-pdf-delimiter-other {
        width: 5.5rem;
        flex: 0 0 auto;
    }
</style>

@code {

    private static readonly (string Value, string Label)[] KvDelimiterSelectOptions =
    [
        (":", "Colon"),
        (";", "Semicolon"),
        ("=", "Equals"),
        ("?", "Question"),
        ("|", "Pipe"),
        ("-", "Dash"),
        (".", "Dot"),
    ];

    private static readonly HashSet<char> KvDelimiterPresetChars =
        [.. KvDelimiterSelectOptions.Select(o => o.Value[0])];

    private readonly Dictionary<string, string> _customDelimiterDraft = new(StringComparer.Ordinal);

    [Parameter]
    public IReadOnlyList<LyoPdfAnnotationResult> Rows { get; set; } = [];

    [Parameter]
    public bool ResultPhase { get; set; }

    [Parameter]
    public EventCallback<LyoPdfAnnotationResult> OnApply { get; set; }

    private static IReadOnlyList<string> GetTableHeaders(IReadOnlyList<IReadOnlyDictionary<string, string?>> rows) => rows.SelectMany(x => x.Keys).Distinct(StringComparer.OrdinalIgnoreCase).ToList();

    private static string GetExtractionSummary(LyoPdfAnnotationResult row)
        => row.ExtractionType switch {
            PdfAnnotationExtractionType.KeyValue => FormatKeyValueExtractionSummary(row),
            PdfAnnotationExtractionType.Table => FormatTableExtractionSummary(row),
            PdfAnnotationExtractionType.BoundingBoxText => FormatPlainTextExtractionSummary(row),
            _ => "Paragraph"
        };

    private static string FormatTableExtractionSummary(LyoPdfAnnotationResult row)
    {
        var h = row.TableHeaders.Count;
        var r = row.TableRows?.Count ?? 0;
        return $"Table ({Plural(h, "header", "headers")}, {Plural(r, "row", "rows")})";
    }

    private static string FormatKeyValueExtractionSummary(LyoPdfAnnotationResult row)
    {
        var layout = row.KeyValueLayout == PdfKeyValueLayout.Vertical ? "Key/Value vertical" : "Key/Value horizontal";
        var k = row.KnownKeys.Count;
        var c = row.ColumnCount < 1 ? 1 : row.ColumnCount;
        return $"{layout} ({Plural(k, "key", "keys")}, {Plural(c, "column", "columns")})";
    }

    private static string FormatPlainTextExtractionSummary(LyoPdfAnnotationResult row)
    {
        var lines = CountNonEmptyLines(row.ExtractedText);
        var c = row.ColumnCount < 1 ? 1 : row.ColumnCount;
        return $"Paragraph ({Plural(lines, "line", "lines")}, {Plural(c, "column", "columns")})";
    }

    private static int CountNonEmptyLines(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return 0;

        return text.Split(["\r\n", "\n", "\r"], StringSplitOptions.None)
            .Count(s => !string.IsNullOrWhiteSpace(s));
    }

    private static string Plural(int n, string singular, string plural)
        => $"{n} {(n == 1 ? singular : plural)}";

    private void SetExtractionType(LyoPdfAnnotationResult row, PdfAnnotationExtractionType value)
    {
        row.ExtractionType = value;
        InvokeAsync(StateHasChanged);
    }

    private void SetYTolerance(LyoPdfAnnotationResult row, double value)
    {
        row.YTolerance = value;
        InvokeAsync(StateHasChanged);
    }

    private void SetKnownKeys(LyoPdfAnnotationResult row, IEnumerable<string> values)
    {
        row.KnownKeys = values.Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        InvokeAsync(StateHasChanged);
    }

    private void SetTableHeaders(LyoPdfAnnotationResult row, IEnumerable<string> values)
    {
        row.TableHeaders = values.Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        if (row.TableKeyColumnLabel is not null &&
            !row.TableHeaders.Any(h => string.Equals(h, row.TableKeyColumnLabel, StringComparison.OrdinalIgnoreCase)))
            row.TableKeyColumnLabel = null;

        InvokeAsync(StateHasChanged);
    }

    private static IReadOnlyList<string> GetTableKeySelectedChips(LyoPdfAnnotationResult row)
    {
        var key = row.TableKeyColumnLabel;
        if (string.IsNullOrWhiteSpace(key) && row.TableHeaders.Count > 0)
            key = row.TableHeaders[0];

        if (string.IsNullOrWhiteSpace(key))
            return [];

        var match = row.TableHeaders.FirstOrDefault(h => string.Equals(h, key, StringComparison.OrdinalIgnoreCase));
        return match is null ? [] : [match];
    }

    private void SetTableKeyChipSelection(LyoPdfAnnotationResult row, IEnumerable<string> selected)
    {
        row.TableKeyColumnLabel = selected.FirstOrDefault(s => !string.IsNullOrWhiteSpace(s))?.Trim();
        InvokeAsync(StateHasChanged);
    }

    private void SetKeyValueLayout(LyoPdfAnnotationResult row, PdfKeyValueLayout value)
    {
        row.KeyValueLayout = value;
        InvokeAsync(StateHasChanged);
    }

    private void SetColumnCount(LyoPdfAnnotationResult row, int value)
    {
        row.ColumnCount = value < 1 ? 1 : value;
        InvokeAsync(StateHasChanged);
    }

    private void SetInferBold(LyoPdfAnnotationResult row, bool on)
    {
        row.InferFormattingFlags = on
            ? row.InferFormattingFlags | PdfInferFormattingFlags.Bold
            : row.InferFormattingFlags & ~PdfInferFormattingFlags.Bold;
        InvokeAsync(StateHasChanged);
    }

    private void SetInferSemicolon(LyoPdfAnnotationResult row, bool on)
    {
        row.InferFormattingFlags = on
            ? row.InferFormattingFlags | PdfInferFormattingFlags.Semicolon
            : row.InferFormattingFlags & ~PdfInferFormattingFlags.Semicolon;
        if (on && string.IsNullOrWhiteSpace(row.KeyValueInferDelimiters))
            row.KeyValueInferDelimiters = ":;";

        InvokeAsync(StateHasChanged);
    }

    private IReadOnlyCollection<string> GetDelimiterSelectedValues(LyoPdfAnnotationResult row)
    {
        var list = new List<string>();
        foreach (var c in row.KeyValueInferDelimiters ?? "") {
            if (char.IsWhiteSpace(c) || char.IsControl(c))
                continue;

            var s = c.ToString();
            if (!list.Contains(s))
                list.Add(s);
        }

        if (list.Count == 0) {
            list.Add(":");
            list.Add(";");
        }

        return list;
    }

    private IEnumerable<char> GetExtraDelimiterChars(LyoPdfAnnotationResult row)
    {
        var seen = new HashSet<char>();
        foreach (var c in row.KeyValueInferDelimiters ?? "") {
            if (char.IsWhiteSpace(c) || char.IsControl(c) || KvDelimiterPresetChars.Contains(c))
                continue;

            if (seen.Add(c))
                yield return c;
        }
    }

    private void SetDelimiterSelectedValues(LyoPdfAnnotationResult row, IEnumerable<string>? values)
    {
        var sel = values?.ToArray() ?? [];
        var ordered = new List<char>();
        foreach (var (val, _) in KvDelimiterSelectOptions) {
            if (val.Length == 1 && sel.Contains(val))
                ordered.Add(val[0]);
        }

        foreach (var s in sel) {
            if (string.IsNullOrEmpty(s) || s.Length != 1)
                continue;

            var c = s[0];
            if (char.IsWhiteSpace(c) || char.IsControl(c) || ordered.Contains(c))
                continue;

            if (KvDelimiterPresetChars.Contains(c))
                continue;

            ordered.Add(c);
        }

        row.KeyValueInferDelimiters = ordered.Count > 0 ? new string([.. ordered]) : ":;";
        InvokeAsync(StateHasChanged);
    }

    private static string DelimiterSelectSummary(IEnumerable<string> selected)
    {
        var parts = selected.Select(static s => s.Length == 1 ? $"‘{s}’" : s).ToArray();
        return parts.Length == 0 ? "" : string.Join(" ", parts);
    }

    private string GetCustomDelimiterDraft(string rowKey) => _customDelimiterDraft.GetValueOrDefault(rowKey) ?? "";

    private void SetCustomDelimiterDraft(LyoPdfAnnotationResult row, string v)
    {
        _customDelimiterDraft[row.Key] = v;
        if (v.Length == 0) {
            InvokeAsync(StateHasChanged);
            return;
        }

        var c = v.Trim()[0];
        if (char.IsWhiteSpace(c) || char.IsControl(c))
            return;

        var current = row.KeyValueInferDelimiters ?? "";
        if (current.Contains(c)) {
            _customDelimiterDraft[row.Key] = "";
            InvokeAsync(StateHasChanged);
            return;
        }

        row.KeyValueInferDelimiters = current + c;
        _customDelimiterDraft[row.Key] = "";
        InvokeAsync(StateHasChanged);
    }

    private void SetInferUnderline(LyoPdfAnnotationResult row, bool on)
    {
        row.InferFormattingFlags = on
            ? row.InferFormattingFlags | PdfInferFormattingFlags.Underline
            : row.InferFormattingFlags & ~PdfInferFormattingFlags.Underline;
        InvokeAsync(StateHasChanged);
    }

    private void SetTableKeyColumn(LyoPdfAnnotationResult row, string? value)
    {
        row.TableKeyColumnLabel = string.IsNullOrWhiteSpace(value) ? null : value.Trim();
        InvokeAsync(StateHasChanged);
    }

}
