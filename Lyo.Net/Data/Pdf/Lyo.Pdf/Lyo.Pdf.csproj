<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>netstandard2.0;net10.0</TargetFrameworks>
        <Description>PDF processing library using PdfPig for reading and PDFsharp for creating and manipulating PDF documents.</Description>
        <PackageTags>pdf pdfpig pdfsharp</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="[10,)"/>
        <PackageReference Include="Microsoft.Extensions.Http" Version="[10,)"/>
        <PackageReference Include="PdfPig" Version="[0.1.13,)"/>
        <PackageReference Include="PDFsharp" Version="[6.2.4,)"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\..\Core\Common\Lyo.Common\Lyo.Common.csproj"/>
        <ProjectReference Include="..\..\..\Core\Lyo.Exceptions\Lyo.Exceptions.csproj"/>
        <ProjectReference Include="..\..\..\Core\Metrics\Lyo.Metrics\Lyo.Metrics.csproj"/>
        <ProjectReference Include="..\..\..\Core\Result\Lyo.Result\Lyo.Result.csproj" />
        <ProjectReference Include="..\Lyo.Pdf.Models\Lyo.Pdf.Models.csproj"/></ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    </ItemGroup>

</Project>
