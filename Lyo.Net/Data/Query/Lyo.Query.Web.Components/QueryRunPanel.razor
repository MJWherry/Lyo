@using System.Text.Json
@using Lyo.Query.Models.Common.Request
@using Lyo.Web.Components.JsonEditor
<MudPaper Elevation="0" Class="pa-4">
    <MudStack Spacing="3">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudSelect T="string"
                       Value="@Run.SelectedHost"
                       ValueChanged="@OnSelectedHostChanged"
                       Label="Host"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Margin="Margin.Dense"
                       Class="run-toolbar-select"
                       Style="min-width: 220px;">
                @foreach (var h in Run.HostEndpoints.Keys) {
                    <MudSelectItem Value="@h">@h</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string"
                       Value="@Run.Route"
                       ValueChanged="@OnRouteChanged"
                       Label="Route"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Margin="Margin.Dense"
                       Class="run-toolbar-select"
                       Style="min-width: 140px;">
                @foreach (var r in RoutesForSelectedHost()) {
                    <MudSelectItem Value="@r">@r</MudSelectItem>
                }
            </MudSelect>
            <MudButtonGroup OverrideStyles="false"
                            Variant="Variant.Outlined"
                            Size="Size.Small"
                            Class="run-endpoint-toggle">
                <MudButton OnClick="@(() => OnQueryRunModeChanged(QueryWorkbenchRunMode.Query))"
                           Variant="@(Run.RunMode == QueryWorkbenchRunMode.Query ? Variant.Filled : Variant.Outlined)"
                           Color="@(Run.RunMode == QueryWorkbenchRunMode.Query ? Color.Primary : Color.Default)">/Query</MudButton>
                <MudButton OnClick="@(() => OnQueryRunModeChanged(QueryWorkbenchRunMode.QueryProject))"
                           Variant="@(Run.RunMode == QueryWorkbenchRunMode.QueryProject ? Variant.Filled : Variant.Outlined)"
                           Color="@(Run.RunMode == QueryWorkbenchRunMode.QueryProject ? Color.Primary : Color.Default)">/QueryProject</MudButton>
            </MudButtonGroup>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@(_loading ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.PlayArrow)"
                       OnClick="@RunQuery"
                       Class="run-query-btn"
                       Disabled="@_loading">
                @(_loading ? "Running…" : "Run Query")
            </MudButton>
        </MudStack>

        <MudExpansionPanels Elevation="0" Outlined="true">
            <MudExpansionPanel Text="API targets (multiple hosts)">
                <MudSimpleTable Dense="true" Hover="true" Bordered="true">
                    <thead>
                    <tr>
                        <th>Base URL</th>
                        <th>Routes (comma-separated)</th>
                        <th style="width: 48px;"></th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in _hostRows) {
                        <tr>
                            <td>
                                <MudTextField @bind-Value="row.Host"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              @onfocusout="OnHostRowFocusOut"/>
                            </td>
                            <td>
                                <MudTextField @bind-Value="row.EndpointsCsv"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              @onfocusout="OnHostRowFocusOut"/>
                            </td>
                            <td>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               OnClick="@(() => RemoveHostRow(row))"
                                               Title="Remove row"/>
                            </td>
                        </tr>
                    }
                    </tbody>
                </MudSimpleTable>
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Class="mt-2"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@AddHostRow">
                    Add host
                </MudButton>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: ui-monospace, monospace;">
            POST @GetRequestUri()
        </MudText>

        @if (_error != null) {
            <MudAlert Severity="Severity.Error">@SafeError(_error)</MudAlert>
        }

        <div class="req-resp-split @(_isResizing ? "is-resizing" : "")"
             style="@QuerySplitCssVariables"
             @ref="_splitContainerRef"
             @onmousemove="OnSplitMouseMove"
             @onmouseup="StopSplitResize"
             @onmouseleave="StopSplitResize">
            <MudPaper Elevation="1"
                      Class="pa-3 h-100 split-pane split-pane-left">
                <div class="pane-content">
                    @{
                        var score = GetCurrentScoreBreakdown();
                    }
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">
                        Request
                        <span class="panel-meta">(@GetSizeLabel(GetRequestSizeBytes()))</span>
                        <span class="panel-meta panel-score">@score.TotalScore QS</span>
                        <MudTooltip Placement="Placement.Bottom">
                            <ChildContent>
                                <MudIcon Icon="@Icons.Material.Filled.Info"
                                         Size="Size.Small"
                                         Class="panel-score-info"/>
                            </ChildContent>
                            <TooltipContent>
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption"><b>Total:</b> @score.TotalScore</MudText>
                                    <MudDivider Class="my-1"/>
                                    <MudText Typo="Typo.caption">Paging: @score.PagingScore</MudText>
                                    <MudText Typo="Typo.caption">Keys: @score.KeysScore</MudText>
                                    <MudText Typo="Typo.caption">Sort: @score.SortScore</MudText>
                                    <MudText Typo="Typo.caption">Include: @score.IncludeScore</MudText>
                                    <MudText Typo="Typo.caption">Computed: @score.ComputedFieldsScore</MudText>
                                    <MudText Typo="Typo.caption">Count Mode: @score.TotalCountModeScore</MudText>
                                    <MudText Typo="Typo.caption">Query Node: @score.WhereClauseScore</MudText>
                                    <MudDivider Class="my-1"/>
                                    <MudText Typo="Typo.caption">Includes: @score.IncludeCount, max depth: @score.IncludeMaxDepth</MudText>
                                    <MudText Typo="Typo.caption">Query nodes: @score.WhereClauseCount, conditions: @score.QueryConditionCount,
                                        sub-wheres: @score.QuerySubClauseCount</MudText>
                                </MudStack>
                            </TooltipContent>
                        </MudTooltip>
                    </MudText>
                    @if (Run.RunMode == QueryWorkbenchRunMode.Query) {
                        <JsonEditor @key="@($"{_requestEditorRenderKey}-q")"
                                    T="QueryReq"
                                    Value="@EntityRequest"
                                    ValueChanged="@OnEntityJsonChanged"
                                    JsonOptions="@JsonOptions"
                                    AllowTreeEditing="true"
                                    DefaultViewMode="@Run.RequestEditorViewMode"
                                    ViewModeChanged="@OnRequestEditorViewModeChanged"
                                    ParseErrorChanged="@OnRequestEditorParseErrorChanged"
                                    SearchTextChanged="@OnRequestEditorSearchTextChanged"/>
                    }
                    else {
                        <JsonEditor @key="@($"{_requestEditorRenderKey}-p")"
                                    T="ProjectionQueryReq"
                                    Value="@ProjectionRequest"
                                    ValueChanged="@OnProjectionJsonChanged"
                                    JsonOptions="@JsonOptions"
                                    AllowTreeEditing="true"
                                    DefaultViewMode="@Run.RequestEditorViewMode"
                                    ViewModeChanged="@OnRequestEditorViewModeChanged"
                                    ParseErrorChanged="@OnRequestEditorParseErrorChanged"
                                    SearchTextChanged="@OnRequestEditorSearchTextChanged"/>
                    }
                    @if (!string.IsNullOrWhiteSpace(_requestEditorParseError)) {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                            @_requestEditorParseError
                        </MudAlert>
                    }
                </div>
            </MudPaper>

            <div class="splitter"
                 role="separator"
                 title="Resize request/response panels"
                 @onmousedown="StartSplitResize"></div>

            <MudPaper Elevation="1"
                      Class="pa-3 h-100 split-pane split-pane-right">
                <div class="pane-content">
                    <div class="d-flex align-center justify-space-between mb-2">
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                            Response
                            @if (_lastResponseElapsedMs.HasValue || _lastResponseSizeBytes.HasValue) {
                                <span class="panel-meta">
                                    (
                                    @if (_lastResponseElapsedMs.HasValue) {
                                        <text>@_lastResponseElapsedMs.Value ms</text>
                                    }
                                    @if (_lastResponseElapsedMs.HasValue && _lastResponseSizeBytes.HasValue) {
                                        <text> • </text>
                                    }
                                    @if (_lastResponseSizeBytes.HasValue) {
                                        <text>@GetSizeLabel(_lastResponseSizeBytes.Value)</text>
                                    }
                                    )
                                </span>
                            }
                        </MudText>
                        @if ((_lastResponseElapsedMs.HasValue || _lastResponseSizeBytes.HasValue || _resultJson.ValueKind != JsonValueKind.Undefined || !string.IsNullOrEmpty(_resultRawText)) && !_loading) {
                            <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                           Size="Size.Small"
                                           OnClick="ClearResponse"
                                           Title="Clear response"/>
                        }
                    </div>
                    @if (_resultJson.ValueKind != JsonValueKind.Undefined && !_loading) {
                        <JsonEditor @key="_responseEditorRenderKey"
                                    T="JsonElement"
                                    Value="@_resultJson"
                                    ValueChanged="@(_ => { })"
                                    Editable="false"
                                    AllowTreeEditing="false"
                                    DefaultViewMode="@_responseEditorDefaultViewMode"
                                    ViewModeChanged="@OnResponseEditorViewModeChanged"
                                    ParseErrorChanged="@OnResponseEditorParseErrorChanged"
                                    SearchTextChanged="@OnResponseEditorSearchTextChanged"/>

                        @if (!string.IsNullOrWhiteSpace(_responseEditorParseError)) {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                                @_responseEditorParseError
                            </MudAlert>
                        }
                    }
                    else if (!string.IsNullOrEmpty(_resultRawText) && !_loading) {
                        <pre class="response-raw-text">@_resultRawText</pre>
                    }
                    else {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Run query to see response.</MudText>
                    }
                </div>
            </MudPaper>
        </div>
    </MudStack>
</MudPaper>

<style>
    .run-query-btn {
        align-self: center;
    }

    .run-toolbar-select {
        align-self: center;
    }

    .run-endpoint-toggle {
        align-self: center;
    }

    .req-resp-split {
        display: flex;
        align-items: stretch;
        gap: 4px;
        min-height: 500px;
    }

    .split-pane {
        min-width: 260px;
        overflow: hidden;
    }

    .split-pane-left {
        box-sizing: border-box;
        width: var(--qrb-split, 50%);
        min-width: 280px;
        max-width: 75%;
    }

    .split-pane-right {
        flex: 1 1 0;
        min-width: 280px;
        min-height: 0;
    }

    .pane-content {
        height: 100%;
        overflow: auto;
    }

    .splitter {
        width: 8px;
        cursor: col-resize;
        background: var(--mud-palette-lines-default);
        border-radius: 4px;
        opacity: 0.65;
        transition: opacity 120ms ease-in-out;
    }

    .splitter:hover {
        opacity: 1;
    }

    .is-resizing {
        user-select: none;
        cursor: col-resize;
    }

    .is-resizing .pane-content {
        pointer-events: none;
    }

    .panel-meta {
        font-size: 0.75rem;
        margin-left: 6px;
        opacity: 0.8;
    }

    .panel-score-info {
        margin-left: 2px;
        vertical-align: text-bottom;
        opacity: 0.75;
        cursor: help;
    }

    .response-raw-text {
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
        white-space: pre-wrap;
        word-break: break-word;
        margin: 0;
        overflow: auto;
    }

    @@media (max-width: 960px) {
        .req-resp-split {
            flex-direction: column;
            /* Definite height so % flex-basis (--qrb-split) resolves on the column main axis */
            height: min(75vh, 780px);
            min-height: 620px;
        }

        .split-pane-left {
            width: 100% !important;
            min-width: 0 !important;
            max-width: none !important;
            flex: 0 0 var(--qrb-split, 50%) !important;
            min-height: 120px;
        }

        .split-pane-right {
            width: 100% !important;
            min-width: 0 !important;
            flex: 1 1 0 !important;
        }

        .splitter {
            width: 100%;
            height: 8px;
            cursor: row-resize;
            flex-shrink: 0;
        }

        .req-resp-split.is-resizing {
            cursor: row-resize;
        }
    }
</style>
