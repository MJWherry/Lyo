<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>Lyo.Query</id>
        <version>1.0.71</version>
        <authors>Matthew Wherry</authors>
        <owners>Matthew Wherry</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>Query filtering and property comparison services for IQueryable. Uses Lyo.Query.Models for query types.</description>
        <summary>Query filtering and property comparison</summary>
        <copyright>Copyright © Lyo</copyright>
        <tags>query filter linq iqueryable</tags>
        <repository type="git" url="https://github.com/mjwherry/Lyo"/>
        <dependencies>
            <group targetFramework="net10.0">
                <dependency id="Lyo.Cache" version="[1.0.71,)"/>
                <dependency id="Lyo.Common" version="[1.0.71,)"/>
                <dependency id="Lyo.Exceptions" version="[1.0.71,)"/>
                <dependency id="Lyo.Metrics" version="[1.0.71,)"/>
                <dependency id="Lyo.Query.Models" version="[1.0.71,)"/>
                <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[10.0.1,)"/>
                <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[10.0.1,)"/>
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="bin/Release/net10.0/*.dll" target="lib/net10.0"/>
        <file src="bin/Release/net10.0/*.pdb" target="lib/net10.0"/>
    </files>
</package>
